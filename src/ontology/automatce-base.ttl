                                                   rdfs:label "max mold temperature"@en ;
                                                   skos:definition "Maximum temperature of the mold used in a manufacturing process"@en .


###  https://w3id.org/pmd/automatce/AUTOMATCE_0030005
<https://w3id.org/pmd/automatce/AUTOMATCE_0030005> rdf:type owl:Class ;
                                                   rdfs:subClassOf <https://w3id.org/pmd/automatce/AUTOMATCE_0030003> ;
                                                   rdfs:label "min mold temperature"@en ;
                                                   skos:definition "Minimum temperature of the mold used in a manufacturing process"@en .


