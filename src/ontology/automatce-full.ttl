                                                          ] ;
                                      rdfs:subClassOf obo:OBI_0000011 ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty obo:OBI_0000293 ;
                                                        owl:someValuesFrom [ rdf:type owl:Class ;
                                                                             owl:unionOf ( obo:BFO_0000027
                                                                                           obo:BFO_0000030
                                                                                         )
                                                                           ]
                                                      ] ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty obo:OBI_0000299 ;
