                                                                     <https://orcid.org/0009-0003-1503-4422> ,
                                                                     <https://orcid.org/0009-0007-7468-3544> ;
                                                     dcterms:description "Application ontology for automotive circular-economy product, material, sustainability, usage, dismantling, engineering and transactional data aligned to PMDCore and BFO 2020." ;
                                                     dcterms:license <https://w3id.org/pmd/automatce.owl#CC-BY-4.0> ;
                                                     dcterms:title "Automotive Circular Economy Ontology" ;
                                                     owl:versionInfo "2026-04-27" .

