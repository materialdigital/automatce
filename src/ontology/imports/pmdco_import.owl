AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/PMD_0020107> "ledeburite"@en)

# Individual: <https://w3id.org/pmd/co/PMD_0020109> (pearlite)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/PMD_0020109> "pearlite"@en)

# Individual: <https://w3id.org/pmd/co/PMD_0020110> (widmanstatten structure)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/PMD_0020110> "widmanstatten structure"@en)

# Individual: <https://w3id.org/pmd/co/PMD_0020111> (martensite)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/PMD_0020111> "martensite"@en)

# Individual: <https://w3id.org/pmd/co/PMD_0020117> (aggregate state solid)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/PMD_0020117> "aggregate state solid"@en)
AnnotationAssertion(skos:definition <https://w3id.org/pmd/co/PMD_0020117> "A state where the bonds between entites trasmit shear forces."@en)

# Individual: <https://w3id.org/pmd/co/PMD_0020118> (aggregate state liquid)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/PMD_0020118> "aggregate state liquid"@en)
AnnotationAssertion(skos:definition <https://w3id.org/pmd/co/PMD_0020118> "A state where the bonds of the entites transmit no shear force."@en)

# Individual: <https://w3id.org/pmd/co/PMD_0020119> (aggregate state gasous)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/PMD_0020119> "aggregate state gasous"@en)
AnnotationAssertion(skos:definition <https://w3id.org/pmd/co/PMD_0020119> "A state where the entities have no bonding."@en)

# Individual: <https://w3id.org/pmd/co/PMD_0020120> (aggregate state plasma)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/PMD_0020120> "aggregate state plasma"@en)
AnnotationAssertion(skos:definition <https://w3id.org/pmd/co/PMD_0020120> "An aggregate state where the entites are atom nuclei and have no bonds."@en)

# Individual: <https://w3id.org/pmd/co/PMD_0020121> (aggregate state atom gas)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/PMD_0020121> "aggregate state atom gas"@en)
AnnotationAssertion(skos:definition <https://w3id.org/pmd/co/PMD_0020121> "A gaseous state where the gas entities are atoms."@en)

# Individual: <https://w3id.org/pmd/co/PMD_0020122> (aggregate state supercritical fluid)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/PMD_0020122> "aggregate state supercritical fluid"@en)
AnnotationAssertion(skos:definition <https://w3id.org/pmd/co/PMD_0020122> "A state with strong bindings between entites that do not transmit shear force."@en)

# Individual: <https://w3id.org/pmd/co/PMD_0020123> (aggregate state mesomorphic)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/PMD_0020123> "aggregate state mesomorphic"@en)
AnnotationAssertion(skos:definition <https://w3id.org/pmd/co/PMD_0020123> "A state where some bonds transmit shear stresses and some do not."@en)

# Individual: <https://w3id.org/pmd/co/PMD_0020124> (aggregate state suprafluid)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/PMD_0020124> "aggregate state suprafluid"@en)
AnnotationAssertion(skos:definition <https://w3id.org/pmd/co/PMD_0020124> "A state with frictionless binding that transmits no shear force between entites."@en)

# Individual: <https://w3id.org/pmd/co/PMD_0020125> (aggregate state suprasolid)

AnnotationAssertion(rdfs:label <https://w3id.org/pmd/co/PMD_0020125> "aggregate state suprasolid"@en)
AnnotationAssertion(skos:definition <https://w3id.org/pmd/co/PMD_0020125> "A state that exhibits suprafluid and solid properties."@en)


