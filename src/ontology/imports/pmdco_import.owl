AnnotationAssertion(rdfs:label obo:OBI_0000835 "manufacturer")
EquivalentClasses(obo:OBI_0000835 ObjectIntersectionOf(ObjectUnionOf(obo:NCBITaxon_9606 obo:OBI_0000245) ObjectSomeValuesFrom(obo:RO_0000087 obo:OBI_0000571)))
