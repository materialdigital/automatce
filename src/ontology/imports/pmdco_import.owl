AnnotationAssertion(obo:IAO_0000115 obo:IAO_0000444 "A planned process of making information, such as literature, music, and software etc., available to the public for sale or for free."@en)
AnnotationAssertion(rdfs:label obo:IAO_0000444 "publishing process"@en)
SubClassOf(obo:IAO_0000444 obo:OBI_0000011)

