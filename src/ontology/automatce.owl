    <!-- http://purl.obolibrary.org/obo/BFO_0000050 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000050">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <obo:IAO_0000115 xml:lang="en">a core relation that holds between a part and its whole</obo:IAO_0000115>
        <rdfs:label xml:lang="en">part of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000051 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000051">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <obo:IAO_0000115 xml:lang="en">a core relation that holds between a whole and its part</obo:IAO_0000115>
        <rdfs:label xml:lang="en">has part</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000054 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000054">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000055"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">has realization</rdfs:label>
        <rdfs:label xml:lang="en">realized in</rdfs:label>
        <skos:definition xml:lang="en">b has realization c =Def c realizes b</skos:definition>
        <skos:example xml:lang="en">As for realizes</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000055 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000055">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
        <obo:IAO_0000115 xml:lang="en">Paraphrase of elucidation: a relation between a process and a realizable entity, where there is some material entity that is bearer of the realizable entity and participates in the process, and the realizable entity comes to be realized in the course of the process</obo:IAO_0000115>
        <rdfs:label xml:lang="en">realizes</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) realizes is a relation between a process b and realizable entity c such that c inheres in some d &amp; for all t, if b has participant d then c exists &amp; the type instantiated by b is correlated with the type instantiated by c</skos:definition>
        <skos:example xml:lang="en">A balding process realizes a disposition to go bald; a studying process realizes a student role; a process of pumping blood realizes the pumping function of a heart</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000196 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000196"/>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000197 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000197"/>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000136 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000136">
        <owl:inverseOf rdf:resource="https://w3id.org/pmd/co/PMD_0000004"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <obo:IAO_0000115 xml:lang="en">A (currently) primitive relation that relates an information artifact to an entity.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">is about</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000219 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000219">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000235"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000001"/>
        <obo:IAO_0000115 xml:lang="en">A primitive, instance-level, relation obtaining between an information content entity and some portion of reality. Denotation is what happens when someone creates an information content entity E in order to specifically refer to something. The only relation between E and the thing is that E can be used to &apos;pick out&apos; the thing. This relation connects those two together. Freedictionary.com sense 3: To signify directly; refer to specifically</obo:IAO_0000115>
        <rdfs:comment xml:lang="en"></rdfs:comment>
        <rdfs:label xml:lang="en">denotes</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000221 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000221">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000417"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/IAO_0000109"/>
        <obo:IAO_0000115 xml:lang="en">m is a quality measurement of q at t. When q is a quality, there is a measurement process p that has specified output m, a measurement datum, that is about q</obo:IAO_0000115>
        <rdfs:label xml:lang="en">is quality measurement of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000235 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000235">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000001"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <obo:IAO_0000115 xml:lang="en">inverse of the relation &apos;denotes&apos;</obo:IAO_0000115>
        <rdfs:label xml:lang="en">denoted by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000417 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000417">
        <obo:IAO_0000115 xml:lang="en">inverse of the relation of is quality measurement of</obo:IAO_0000115>
        <rdfs:label xml:lang="en">is quality measured as</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000293 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/OBI_0000293">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000295"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <obo:IAO_0000115>The inverse property of is specified input of</obo:IAO_0000115>
        <rdfs:label xml:lang="en">has specified input</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000295 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/OBI_0000295">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000056"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <obo:IAO_0000115>A relation between a completely executed planned process and a continuant participating in that process that is not created during the process. The presence of the continuant during the process is explicitly specified in the plan specification which the process realizes the concretization of.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">is specified input of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000299 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/OBI_0000299">
        <owl:equivalentProperty>
            <rdf:Description>
                <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
            </rdf:Description>
        </owl:equivalentProperty>
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <obo:IAO_0000115>The inverse property of is specified output of</obo:IAO_0000115>
        <rdfs:label xml:lang="en">has specified output</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000312 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/OBI_0000312">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000056"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <obo:IAO_0000115 xml:lang="en">A relation between a completely executed planned process and a continuant participating in that process. The presence of the continuant at the end of the process is explicitly specified in the objective specification which the process realizes the concretization of.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">is specified output of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000417 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/OBI_0000417">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/IAO_0000005"/>
        <obo:IAO_0000115 xml:lang="en">This relation obtains between a planned process and a objective specification when the criteria specified in the objective specification are met at the end of the planned process.</obo:IAO_0000115>
        <rdfs:label>achieves_planned_objective</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0001927 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/OBI_0001927">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
        <owl:inverseOf rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/OBI_0001933"/>
        <obo:IAO_0000115 xml:lang="en">A relation between a value specification and an entity which the specification is about.</obo:IAO_0000115>
        <rdfs:label>specifies value of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0001938 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/OBI_0001938">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/OBI_0001933"/>
        <obo:IAO_0000115 xml:lang="en">A relation between an information content entity and a value specification that specifies its value.</obo:IAO_0000115>
        <rdfs:label>has value specification</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000052 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000052">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000053"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <obo:IAO_0000115 xml:lang="en">a relation between a specifically dependent continuant (the characteristic) and any other entity (the bearer), in which the characteristic depends on the bearer for its existence.</obo:IAO_0000115>
        <rdfs:comment>Note that this relation was previously called &quot;inheres in&quot;, but was changed to be called &quot;characteristic of&quot; because BFO2 uses &quot;inheres in&quot; in a more restricted fashion. This relation differs from BFO2:inheres_in in two respects: (1) it does not impose a range constraint, and thus it allows qualities of processes, as well as of information entities, whereas BFO2 restricts inheres_in to only apply to independent continuants (2) it is declared functional, i.e. something can only be a characteristic of one thing.</rdfs:comment>
        <rdfs:label xml:lang="en">characteristic of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000053 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000053">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000020"/>
        <obo:IAO_0000115 xml:lang="en">Inverse of characteristic_of</obo:IAO_0000115>
        <rdfs:label xml:lang="en">has characteristic</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000056 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000056">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000002"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <obo:IAO_0000115 xml:lang="en">a relation between a continuant and a process, in which the continuant is somehow involved in the process</obo:IAO_0000115>
        <rdfs:label xml:lang="en">participates in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000057 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000057">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000002"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000051"/>
            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/RO_0000057"/>
        </owl:propertyChainAxiom>
        <obo:IAO_0000115 xml:lang="en">a relation between a process and a continuant, in which the continuant is somehow involved in the process</obo:IAO_0000115>
        <rdfs:label xml:lang="en">has participant</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000058 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000058">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000059"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000015"/>
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000020"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <obo:IAO_0000115 xml:lang="en">A relationship between a generically dependent continuant and a specifically dependent continuant or process, in which the generically dependent continuant depends on some independent continuant or process in virtue of the fact that the specifically dependent continuant or process also depends on that same independent continuant. A generically dependent continuant may be concretized as multiple specifically dependent continuants or processes.</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">A relationship between a generically dependent continuant and a specifically dependent continuant, in which the generically dependent continuant depends on some independent continuant in virtue of the fact that the specifically dependent continuant also depends on that same independent continuant. A generically dependent continuant may be concretized as multiple specifically dependent continuants.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">is concretized as</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000059 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000059">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000015"/>
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000020"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <obo:IAO_0000115 xml:lang="en">A relationship between a specifically dependent continuant and a generically dependent continuant, in which the generically dependent continuant depends on some independent continuant in virtue of the fact that the specifically dependent continuant also depends on that same independent continuant. Multiple specifically dependent continuants can concretize the same generically dependent continuant.</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">A relationship between a specifically dependent continuant or process and a generically dependent continuant, in which the generically dependent continuant depends on some independent continuant in virtue of the fact that the specifically dependent continuant or process also depends on that same independent continuant. Multiple specifically dependent continuants or processes can concretize the same generically dependent continuant.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">concretizes</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000079 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000079">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000085"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000034"/>
        <obo:IAO_0000115 xml:lang="en">a relation between a function and an independent continuant (the bearer), in which the function specifically depends on the bearer for its existence</obo:IAO_0000115>
        <rdfs:comment>This relation is modeled after the BFO relation of the same name which was in BFO2, but is used in a more restricted sense - specifically, we model this relation as functional (inherited from characteristic-of). Note that this relation is now removed from BFO2020.</rdfs:comment>
        <rdfs:label xml:lang="en">function of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000080 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000080">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
        <rdfs:domain>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000019"/>
                    <owl:Class>
                        <owl:complementOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:domain>
        <obo:IAO_0000115 xml:lang="en">a relation between a quality and an independent continuant (the bearer), in which the quality specifically depends on the bearer for its existence</obo:IAO_0000115>
        <rdfs:comment>This relation is modeled after the BFO relation of the same name which was in BFO2, but is used in a more restricted sense - specifically, we model this relation as functional (inherited from characteristic-of). Note that this relation is now removed from BFO2020.</rdfs:comment>
        <rdfs:label xml:lang="en">quality of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000081 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000081">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
        <obo:IAO_0000115 xml:lang="en">a relation between a role and an independent continuant (the bearer), in which the role specifically depends on the bearer for its existence</obo:IAO_0000115>
        <rdfs:comment>This relation is modeled after the BFO relation of the same name which was in BFO2, but is used in a more restricted sense - specifically, we model this relation as functional (inherited from characteristic-of). Note that this relation is now removed from BFO2020.</rdfs:comment>
        <rdfs:label xml:lang="en">role of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000085 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000085">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000053"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000004"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000034"/>
        <obo:IAO_0000115 xml:lang="en">a relation between an independent continuant (the bearer) and a function, in which the function specifically depends on the bearer for its existence</obo:IAO_0000115>
        <rdfs:label xml:lang="en">has function</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000086 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000086">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000053"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <obo:IAO_0000115 xml:lang="en">a relation between an independent continuant (the bearer) and a quality, in which the quality specifically depends on the bearer for its existence</obo:IAO_0000115>
        <rdfs:label xml:lang="en">has quality</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000087 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000087">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000053"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000004"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <obo:IAO_0000115 xml:lang="en">a relation between an independent continuant (the bearer) and a role, in which the role specifically depends on the bearer for its existence</obo:IAO_0000115>
        <rdfs:label xml:lang="en">has role</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000091 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000091">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000053"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000092"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000004"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <obo:IAO_0000115 xml:lang="en">a relation between an independent continuant (the bearer) and a disposition, in which the disposition specifically depends on the bearer for its existence</obo:IAO_0000115>
        <rdfs:label xml:lang="en">has disposition</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0000092 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0000092">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
        <obo:IAO_0000115>inverse of has disposition</obo:IAO_0000115>
        <rdfs:comment>This relation is modeled after the BFO relation of the same name which was in BFO2, but is used in a more restricted sense - specifically, we model this relation as functional (inherited from characteristic-of). Note that this relation is now removed from BFO2020.</rdfs:comment>
        <rdfs:label xml:lang="en">disposition of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0002233 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0002233"/>
    


    <!-- http://purl.obolibrary.org/obo/RO_0002234 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0002234">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
        <obo:IAO_0000115>p has output c iff c is a participant in p, c is present at the end of p, and c is not present in the same state at the beginning of p.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">has output</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0002351 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0002351"/>
    


    <!-- http://purl.obolibrary.org/obo/RO_0002353 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0002353">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0000056"/>
        <obo:IAO_0000115>inverse of has output</obo:IAO_0000115>
        <rdfs:label xml:lang="en">output of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0009006 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0009006">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0009007"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000020"/>
        <obo:IAO_0000115 xml:lang="en">A relation between an assay and a characteristic, in which the assay generates a data item which is a measure of a characteristic.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">assay measures characteristic</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0009007 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0009007">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000020"/>
        <obo:IAO_0000115 xml:lang="en">Inverse of &apos;assay measures characteristic&apos;</obo:IAO_0000115>
        <rdfs:label xml:lang="en">characteristic measured by assay</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/STATO_0000102 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/STATO_0000102">
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000055"/>
            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/RO_0000059"/>
        </owl:propertyChainAxiom>
        <obo:IAO_0000115 xml:lang="en">relationship between a planned process and the plan specification that it carries out; it is defined as equivalent to the composed relationship (realizes o concretizes)</obo:IAO_0000115>
        <rdfs:label>executes</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pmd/co/PMD_0000004 -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pmd/co/PMD_0000004">
        <rdfs:label xml:lang="en">is subject of</rdfs:label>
        <skos:definition xml:lang="en">Inverse of &apos;is about&apos;.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pmd/co/PMD_0000077 -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pmd/co/PMD_0000077">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/pmd/co/PMD_0000004"/>
        <rdfs:label xml:lang="en">specified by value</rdfs:label>
        <skos:definition xml:lang="en">A relation between an entity and a value specification which is about this entity.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pmd/co/PMD_0001028 -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pmd/co/PMD_0001028">
        <owl:inverseOf rdf:resource="https://w3id.org/pmd/co/PMD_0001029"/>
        <rdfs:label xml:lang="en">in response to</rdfs:label>
        <skos:definition xml:lang="en">inverse of responds with</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pmd/co/PMD_0001029 -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pmd/co/PMD_0001029">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
        <rdfs:label xml:lang="en">responds with</rdfs:label>
        <skos:definition xml:lang="en">The realizable entity must be &quot;stimulated&quot; by some Stimulus in order to respond with the Response. The bearer of the realizable entity must participate in Stimulation as well as in Response.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pmd/log/LOG_1900001 -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pmd/log/LOG_1900001">
        <rdfs:domain>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000040"/>
                    <owl:Class>
                        <owl:complementOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://xmlns.com/foaf/0.1/Person"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/log/LOG_1000050"/>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000027"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002351"/>
                                <owl:someValuesFrom rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:label xml:lang="en">acts on behalf of</rdfs:label>
        <skos:definition>relation from a material entity to a person or a group of agents or engineered system that holds when the material entity participates in some planned process in order to fulfill an objective for the person or group of agents or engineered system</skos:definition>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.obolibrary.org/obo/BFO_0000001 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000001">
        <rdfs:label xml:lang="en">entity</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) An entity is anything that exists or has existed or will exist</skos:definition>
        <skos:example xml:lang="en">Julius Caesar; the Second World War; your body mass index; Verdi&apos;s Requiem</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000002 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000002">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000001"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000002"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <owl:disjointWith>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
            </owl:Restriction>
        </owl:disjointWith>
        <rdfs:label xml:lang="en">continuant</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A continuant is an entity that persists, endures, or continues to exist through time while maintaining its identity</skos:definition>
        <skos:example xml:lang="en">A human being; a tennis ball; a cave; a region of space; someone&apos;s temperature</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000003 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000003">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000001"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000002"/>
            </owl:Restriction>
        </owl:disjointWith>
        <rdfs:label xml:lang="en">occurrent</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) An occurrent is an entity that unfolds itself in time or it is the start or end of such an entity or it is a temporal or spatiotemporal region</skos:definition>
        <skos:example xml:lang="en">As for process, history, process boundary, spatiotemporal region, zero-dimensional temporal region, one-dimensional temporal region, temporal interval, temporal instant.</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000004 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000004">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000002"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000004"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/BFO_0000020"/>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:label xml:lang="en">independent continuant</rdfs:label>
        <skos:definition xml:lang="en">b is an independent continuant =Def b is a continuant &amp; there is no c such that b specifically depends on c or b generically depends on c</skos:definition>
        <skos:example xml:lang="en">An atom; a molecule; an organism; a heart; a chair; the bottom right portion of a human torso; a leg; the interior of your mouth; a spatial region; an orchestra</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000015 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000015">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:label xml:lang="en">process</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) p is a process means p is an occurrent that has some temporal proper part and for some time t, p has some material entity as participant</skos:definition>
        <skos:example xml:lang="en">An act of selling; the life of an organism; a process of sleeping; a process of cell-division; a beating of the heart; a process of meiosis; the taxiing of an aircraft; the programming of a computer</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000016 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000016">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:label xml:lang="en">disposition</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A disposition b is a realizable entity such that if b ceases to exist then its bearer is physically changed &amp; b&apos;s realization occurs when and because this bearer is in some special physical circumstances &amp; this realization occurs in virtue of the bearer&apos;s physical make-up</skos:definition>
        <skos:example xml:lang="en">An atom of element X has the disposition to decay to an atom of element Y; the cell wall is disposed to transport cellular material through endocytosis and exocytosis; certain people have a predisposition to colon cancer; children are innately disposed to categorize objects in certain ways</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000017 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000017">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000020"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">realizable entity</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A realizable entity is a specifically dependent continuant that inheres in some independent continuant which is not a spatial region &amp; which is of a type some instances of which are realized in processes of a correlated type</skos:definition>
        <skos:example xml:lang="en">The role of being a doctor; the role of this boundary to delineate where Utah and Colorado meet; the function of your reproductive organs; the disposition of your blood to coagulate; the disposition of this piece of metal to conduct electricity</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000019 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000019">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000020"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">quality</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A quality is a specifically dependent continuant that, in contrast to roles and dispositions, does not require any further process in order to be realized</skos:definition>
        <skos:example xml:lang="en">The colour of a tomato; the ambient temperature of this portion of air; the length of the circumference of your waist; the shape of your nose; the shape of your nostril; the mass of this piece of gold</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000020 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000020">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000002"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000020"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:label xml:lang="en">specifically dependent continuant</rdfs:label>
        <skos:definition xml:lang="en">b is a specifically dependent continuant =Def b is a continuant &amp; there is some independent continuant c which is not a spatial region &amp; which is such that b specifically depends on c</skos:definition>
        <skos:example xml:lang="en">(with multiple bearers) John&apos;s love for Mary; the ownership relation between John and this statue; the relation of authority between John and his subordinates</skos:example>
        <skos:example xml:lang="en">(with one bearer) The mass of this tomato; the pink colour of a medium rare piece of grilled filet mignon at its centre; the smell of this portion of mozzarella; the disposition of this fish to decay; the role of being a doctor; the function of this heart to pump blood; the shape of this hole</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000023 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000023">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
        <rdfs:label xml:lang="en">role</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A role b is a realizable entity such that b exists because there is some single bearer that is in some special physical, social, or institutional set of circumstances in which this bearer does not have to be &amp; b is not such that, if it ceases to exist, then the physical make-up of the bearer is thereby changed</skos:definition>
        <skos:example xml:lang="en">The priest role; the student role; the role of subject in a clinical trial; the role of a stone in marking a property boundary; the role of a boundary to demarcate two neighbouring administrative territories; the role of a building in serving as a military target</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000024 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000024">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:label xml:lang="en">fiat object part</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A fiat object part b is a material entity &amp; such that if b exists then it is continuant part of some object c &amp; demarcated from the remainder of c by one or more fiat surfaces</skos:definition>
        <skos:example xml:lang="en">The upper and lower lobes of the left lung; the dorsal and ventral surfaces of the body; the Western hemisphere of the Earth; the FMA:regional parts of an intact human body</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000027 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000027">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:label xml:lang="en">object aggregate</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) An object aggregate is a material entity consisting exactly of a plurality (≥1) of objects as member parts which together form a unit</skos:definition>
        <skos:example xml:lang="en">The aggregate of the musicians in a symphony orchestra and their instruments; the aggregate of bearings in a constant velocity axle joint; the nitrogen atoms in the atmosphere; a collection of cells in a blood biobank</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000029 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000029">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000141"/>
        <rdfs:label xml:lang="en">site</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A site is a three-dimensional immaterial entity whose boundaries either (partially or wholly) coincide with the boundaries of one or more material entities or have locations determined in relation to some material entity</skos:definition>
        <skos:example xml:lang="en">A hole in a portion of cheese; a rabbit hole; the Grand Canyon; the Piazza San Marco; the kangaroo-joey-containing hole of a kangaroo pouch; your left nostril (a fiat part - the opening - of your left nasal cavity); the lumen of your gut; the hold of a ship; the interior of the trunk of your car; hole in an engineered floor joist</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000030 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000030">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:label xml:lang="en">object</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) An object is a material entity which manifests causal unity &amp; is of a type instances of which are maximal relative to the sort of causal unity manifested</skos:definition>
        <skos:example xml:lang="en">An organism; a fish tank; a planet; a laptop; a valve; a block of marble; an ice cube</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000031 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000031">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000002"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">generically dependent continuant</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A generically dependent continuant is an entity that exists in virtue of the fact that there is at least one of what may be multiple copies which is the content or the pattern that multiple copies would share</skos:definition>
        <skos:example xml:lang="en">The pdf file on your laptop; the pdf file that is a copy thereof on my laptop; the sequence of this protein molecule; the sequence that is a copy thereof in that protein molecule; the content that is shared by a string of dots and dashes written on a page and the transmitted Morse code signal; the content of a sentence; an engineering blueprint</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000034 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000034">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:label xml:lang="en">function</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A function is a disposition that exists in virtue of its bearer&apos;s physical make-up &amp; this physical make-up is something the bearer possesses because it came into being either through evolution (in the case of natural biological entities) or through intentional design (in the case of artefacts) in order to realize processes of a certain sort</skos:definition>
        <skos:example xml:lang="en">The function of a hammer to drive in nails; the function of a heart pacemaker to regulate the beating of a heart through electricity</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000040 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000040">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000004"/>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/BFO_0000141"/>
        <obo:IAO_0000115 xml:lang="en">An independent continuant that is spatially extended whose identity is independent of that of other entities and can be maintained through time.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">material entity</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) A material entity is an independent continuant has some portion of matter as continuant part</skos:definition>
        <skos:example xml:lang="en">A human being; the undetached arm of a human being; an aggregate of human beings</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000141 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000141">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000004"/>
        <rdfs:label xml:lang="en">immaterial entity</rdfs:label>
        <skos:definition xml:lang="en">b is an immaterial entity =Def b is an independent continuant which is such that there is no time t when it has a material entity as continuant part</skos:definition>
        <skos:example xml:lang="en">As for fiat point, fiat line, fiat surface, site</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000145 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000145">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">relational quality</rdfs:label>
        <skos:definition xml:lang="en">b is a relational quality =Def b is a quality &amp; there exists c and d such that c and d are not identical &amp; b specifically depends on c &amp; b specifically depends on d</skos:definition>
        <skos:example xml:lang="en">A marriage bond; an instance of love; an obligation between one person and another</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/COB_0000035 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/COB_0000035">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000082"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000055"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBI_0000260"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/GO_0008150"/>
        <rdfs:label xml:lang="en">completely executed planned process</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/COB_0000082 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/COB_0000082">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <obo:IAO_0000115 xml:lang="en">A process that is initiated by an agent who intends to carry out a plan to achieve an objective through one or more actions as described in a plan specification.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">planned process</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/GO_0008150 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/GO_0008150">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A biological process is the execution of a genetically-encoded biological module or program. It consists of all the steps required to achieve the specific biological objective of the module. A biological process is accomplished by a particular set of molecular functions carried out by specific gene products (or macromolecular complexes), often in a highly regulated manner and in a particular temporal sequence.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">biological process</rdfs:label>
        <rdfs:label>biological_process</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000005 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000005">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000033"/>
        <obo:IAO_0000115 xml:lang="en">A directive information entity that describes an intended process endpoint. When part of a plan specification the concretization is realized in a planned process in which the bearer tries to effect the world so that the process endpoint is achieved.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">objective specification</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000007 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000007">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000033"/>
        <obo:IAO_0000115 xml:lang="en">A directive information entity that describes an action the bearer will take.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">action specification</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000010 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000010">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000104"/>
        <obo:IAO_0000115 xml:lang="en">Software is a plan specification composed of a series of instructions that can be 
interpreted by or directly executed by a processing unit.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">software</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000027 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000027">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <obo:IAO_0000115 xml:lang="en">An information content entity that is intended to be a truthful statement about something (modulo, e.g., measurement precision or other systematic errors) and is constructed/acquired by a method which reliably tends to produce (approximately) truthful statements.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">data item</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000030 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000030">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000001"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A generically dependent continuant that is about some thing.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">information content entity</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000033 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000033">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">An information content entity whose concretizations indicate to their bearer how to realize them in a process.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">directive information entity</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000104 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000104">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000033"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0000005"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0000007"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A directive information entity with action specifications and objective specifications as parts, and that may be concretized as a realizable entity that, if realized, is realized in a process in which the bearer tries to achieve the objectives by taking the actions specified.</obo:IAO_0000115>
        <rdfs:comment xml:lang="en">2/3/2009 Comment from OBI review.

Action specification not well enough specified.
Conditional specification not well enough specified.
Question whether all plan specifications have objective specifications.

Request that IAO either clarify these or change definitions not to use them</rdfs:comment>
        <rdfs:label xml:lang="en">plan specification</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000109 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000109">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0001938"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBI_0001933"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A measurement datum is an information content entity that is a recording of the output of a measurement such as produced by a device.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">measurement datum</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000310 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000310">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <obo:IAO_0000115 xml:lang="en">A collection of information content entities intended to be understood together as a whole</obo:IAO_0000115>
        <rdfs:label xml:lang="en">document</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000311 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000311">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000310"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                        <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0000444"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000310"/>
        <obo:IAO_0000115 xml:lang="en">A document that is the output of a publishing process.</obo:IAO_0000115>
        <rdfs:comment xml:lang="en">Revisit the term in Octorber 2020. Improve the defintion.</rdfs:comment>
        <rdfs:label xml:lang="en">publication</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000444 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000444">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <obo:IAO_0000115 xml:lang="en">A planned process of making information, such as literature, music, and software etc., available to the public for sale or for free.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">publishing process</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0020000 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0020000">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000030"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000219"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000001"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0020010"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000219"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000001"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0020010"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">An information content entity that is the outcome of a dubbing process and is used to refer to one instance of entity shared by a group of people to refer to that individual entity.</obo:IAO_0000115>
        <rdfs:comment xml:lang="en">Sep 29, 2016: The current definition has been amended from the previous version: &quot;A proper name is an information content entity that is the outcome of a dubbing process and is used to refer to one instance of entity shared by a group of people to refer to that individual entity.&quot; to more accuratly reflect the necessary and sufficient condition on the class. (MB)</rdfs:comment>
        <rdfs:label xml:lang="en">identifier</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0020010 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0020010">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/COB_0000035"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000299"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000299"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A planned process that provides a reference to an individual entity shared by a group of subscribers to refer to that individual entity.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">identifier creating process</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/NCBITaxon_9606 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/NCBITaxon_9606">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:label>Homo sapiens</rdfs:label>
        <rdfs:label>homo sapiens</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000011 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000011">
        <obo:IAO_0000115 xml:lang="en">A process that realizes a plan which is the concretization of a plan specification.</obo:IAO_0000115>
        <rdfs:label>obsolete planned process</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000067 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000067">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBI_0000070"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">a role that inheres in a material entity that is realized in an assay in which data is generated about the bearer of the evaluant role</obo:IAO_0000115>
        <rdfs:label xml:lang="en">evaluant role</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000070 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000070">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000293"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000299"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000055"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBI_0000067"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000293"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000040"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBI_0000067"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000299"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000027"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                                <owl:someValuesFrom>
                                    <owl:Class>
                                        <owl:intersectionOf rdf:parseType="Collection">
                                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000040"/>
                                            <owl:Restriction>
                                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                                                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBI_0000067"/>
                                            </owl:Restriction>
                                        </owl:intersectionOf>
                                    </owl:Class>
                                </owl:someValuesFrom>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000417"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0000005"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0009006"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000019"/>
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000005"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A planned process that has the objective to produce information about a material entity (the evaluant) by examining it.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">assay</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000245 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000245">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <obo:IAO_0000115 xml:lang="en">An entity that can bear roles, has members, and has a set of organization rules. Members of organizations are either organizations themselves or individual people. Members can bear specific organization member roles that are determined in the organization rules. The organization rules also determine how decisions are made on behalf of the organization by the organization members.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">organization</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000260 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000260">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000059"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0000104"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A plan is a realizable entity that is the inheres in a bearer who is committed to realizing it as a completely executed planned process.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">plan</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000571 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000571">
        <owl:equivalentClass rdf:resource="https://w3id.org/pmd/log/LOG_1000061"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/log/LOG_1000054"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/NCBITaxon_9606"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OBI_0000245"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">Manufacturer role is a role which inheres in a person or organization and which is realized by a manufacturing process.</obo:IAO_0000115>
        <rdfs:label>manufacturer role</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0000835 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000835">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/NCBITaxon_9606"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OBI_0000245"/>
                        </owl:unionOf>
                    </owl:Class>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBI_0000571"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000087"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBI_0000571"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A person or organization that has a manufacturer role.</obo:IAO_0000115>
        <rdfs:label>manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0001930 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0001930">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0001933"/>
        <obo:IAO_0000115 xml:lang="en">A value specification that is specifies one category out of a fixed number of nominal categories</obo:IAO_0000115>
        <rdfs:label>categorical value specification</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0001933 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0001933">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <obo:IAO_0000115 xml:lang="en">An information content entity that specifies a value within a classification scheme or on a quantitative scale.</obo:IAO_0000115>
        <rdfs:label>value specification</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2004/02/skos/core#Concept -->

    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#ConceptScheme -->

    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    


    <!-- http://www.w3.org/ns/org#FormalOrganization -->

    <owl:Class rdf:about="http://www.w3.org/ns/org#FormalOrganization"/>
    


    <!-- http://xmlns.com/foaf/0.1/Person -->

    <owl:Class rdf:about="http://xmlns.com/foaf/0.1/Person"/>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000002 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000002">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:comment xml:lang="en">This role is realized when the material enters the supply chain or the hopper of a processing machine.</rdfs:comment>
        <rdfs:label xml:lang="en">raw material role</rdfs:label>
        <skos:definition xml:lang="en">A role borne by a material entity when it functions as an input to a manufacturing process prior to transformation or processing.</skos:definition>
        <skos:example xml:lang="en">Plastic granules sitting in a silo waiting to be fed into an extruder bear this role.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000003 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000003">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:comment xml:lang="en">Additives are distinct from fillers (which bulk up volume) and the matrix. They perform specific chemical or physical modifications.</rdfs:comment>
        <rdfs:label xml:lang="en">additive role</rdfs:label>
        <skos:definition xml:lang="en">A role borne by a substance intentionally added in relatively small amounts to modify the processing characteristics, performance properties, or cost of a base material.</skos:definition>
        <skos:example xml:lang="en">UV stabilizers added to dashboard polymers to prevent sun damage; Plasticizers added to PVC.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000004 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000004">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000868"/>
        <owl:disjointWith rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0000005"/>
        <rdfs:comment xml:lang="en">Organic colorants (dyes) offer high color strength and brightness but may have lower thermal stability than pigments.</rdfs:comment>
        <rdfs:label xml:lang="en">organic colorant</rdfs:label>
        <skos:definition xml:lang="en">A complex organic chemical compound used to impart color, typically soluble in the medium.</skos:definition>
        <skos:example xml:lang="en">Azo dyes used in interior textile coloring.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000005 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000005">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000002"/>
        <rdfs:comment xml:lang="en">Inorganic colorants (pigments) are generally insoluble and provide opacity and high heat stability.</rdfs:comment>
        <rdfs:label xml:lang="en">inorganic colorant</rdfs:label>
        <skos:definition xml:lang="en">A mineral-based chemical compound, usually an oxide or sulfide, used to impart color.</skos:definition>
        <skos:example xml:lang="en">Titanium dioxide (white) used in car paints.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000006 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000006">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0000003"/>
        <rdfs:comment xml:lang="en">This role can be borne by organic dyes or inorganic pigments.</rdfs:comment>
        <rdfs:label xml:lang="en">colorant role</rdfs:label>
        <skos:definition xml:lang="en">A role borne by an additive substance when its primary function is to impart color to a material.</skos:definition>
        <skos:example xml:lang="en">Carbon black acting as a pigment to turn a tire black.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000007 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000007">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000952"/>
        <rdfs:comment xml:lang="en">For brittle materials, this is equal to tensile strength. For ductile materials, it may be lower than the yield point.</rdfs:comment>
        <rdfs:label xml:lang="en">stress at break</rdfs:label>
        <skos:definition xml:lang="en">The tensile stress recorded at the moment of rupture of the specimen.</skos:definition>
        <skos:example xml:lang="en">A value of 150 MPa for a GF-reinforced polymer.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000008 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000008">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:comment xml:lang="en">Can be defined descriptively (Red) or metrologically (L*a*b* coordinates).</rdfs:comment>
        <rdfs:label xml:lang="en">color</rdfs:label>
        <skos:definition xml:lang="en">The quality of an object or substance with respect to light reflected by the object, usually determined visually by measurement of hue, saturation, and brightness.</skos:definition>
        <skos:example xml:lang="en">The &apos;Piano Black&apos; finish on a B-pillar trim.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000009 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000009">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0050004"/>
        <rdfs:comment xml:lang="en">Polyamides are semi-crystalline polymers known for good thermal and chemical resistance.</rdfs:comment>
        <rdfs:label xml:lang="en">polyamide</rdfs:label>
        <skos:definition xml:lang="en">A polymer containing repeating amide (-CONH-) linkages in the polymer backbone.</skos:definition>
        <skos:example xml:lang="en">Nylon 6, Nylon 12, Nylon 66.</skos:example>
        <co:PMD_0050117>PA</co:PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000010 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000010">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0000009"/>
        <rdfs:comment xml:lang="en">PA66 has a higher melting point (~260°C) than PA6 but absorbs moisture which affects dimensional stability.</rdfs:comment>
        <rdfs:label xml:lang="en">PA66</rdfs:label>
        <skos:definition xml:lang="en">A semicrystalline thermoplastic polyamide synthesized from hexamethylenediamine and adipic acid.</skos:definition>
        <skos:example xml:lang="en">Material used for cylinder head covers and radiator end tanks.</skos:example>
        <co:PMD_0050117>PA66</co:PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000011 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000011">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000577"/>
        <rdfs:comment xml:lang="en">The addition of 25% glass fiber significantly increases stiffness and tensile strength compared to neat PA66.</rdfs:comment>
        <rdfs:label xml:lang="en">PA66-GF25</rdfs:label>
        <skos:definition xml:lang="en">A composite material consisting of a Polyamide 66 matrix reinforced with 25% glass fiber by mass.</skos:definition>
        <skos:example xml:lang="en">Structural components in the engine bay requiring high stiffness at elevated temperatures.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000012 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000012">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000891"/>
        <rdfs:comment xml:lang="en">In PMD logic, this is a disconnected aggregate because the individual filaments in a bundle are distinct objects.</rdfs:comment>
        <rdfs:label xml:lang="en">fiber</rdfs:label>
        <skos:definition xml:lang="en">A class of materials that are continuous filaments or are in discrete elongated pieces, similar to lengths of thread.</skos:definition>
        <skos:example xml:lang="en">Carbon fiber tow, Aramid fibers.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000013 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000013">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0000012"/>
        <rdfs:comment xml:lang="en">Used extensively as a reinforcement agent in polymer matrix composites.</rdfs:comment>
        <rdfs:label xml:lang="en">glass fiber</rdfs:label>
        <skos:definition xml:lang="en">A material consisting of numerous extremely fine fibers of glass.</skos:definition>
        <skos:example xml:lang="en">E-Glass used to reinforce PA66 for automotive pedals.</skos:example>
        <co:PMD_0050117>GF</co:PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000014 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000014">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020102"/>
        <rdfs:comment xml:lang="en">Commonly denoted as wt%. PA66-GF25 implies a value of 0.25 or 25%.</rdfs:comment>
        <rdfs:label xml:lang="en">fiber material content mass fraction</rdfs:label>
        <skos:definition xml:lang="en">The ratio of the mass of the fiber reinforcement to the total mass of the composite material.</skos:definition>
        <skos:example xml:lang="en">25% mass fraction in PA66-GF25.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000015 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000015">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020104"/>
        <rdfs:comment xml:lang="en">Volume fraction is more critical for micromechanical modeling (e.g., Rule of Mixtures) than mass fraction.</rdfs:comment>
        <rdfs:label xml:lang="en">fiber material content volume fraction</rdfs:label>
        <skos:definition xml:lang="en">The ratio of the volume of the fiber reinforcement to the total volume of the composite material.</skos:definition>
        <skos:example xml:lang="en">Approximately 14-15% volume fraction corresponds to 25% mass fraction for Glass/PA66.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000016 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000016">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:label xml:lang="en">identifier at manufacturer</rdfs:label>
        <skos:definition xml:lang="en">A unique string or code assigned by a manufacturer to identify a specific product grade.</skos:definition>
        <skos:example xml:lang="en">BASF code &apos;A3WG6&apos; for a specific Ultramid grade.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000017 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000017">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:label xml:lang="en">identifier name at manufacturer</rdfs:label>
        <skos:definition xml:lang="en">The brand or trade name used for marketing the material.</skos:definition>
        <skos:example xml:lang="en">&apos;Zytel&apos; (DuPont) or &apos;Durethan&apos; (Lanxess).</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000018 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000018">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:label xml:lang="en">material designation</rdfs:label>
        <skos:definition xml:lang="en">A string following a standard nomenclature (e.g., ISO 1043) to describe the material composition.</skos:definition>
        <skos:example xml:lang="en">PA66-GF25</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000019 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000019">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:label xml:lang="en">material identifier</rdfs:label>
        <skos:definition xml:lang="en">A globally unique identifier (GUID) or database key for the material entry.</skos:definition>
        <skos:example xml:lang="en">Catena-X Material Twin ID.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000020 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000020">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:label xml:lang="en">batch identifier</rdfs:label>
        <skos:definition xml:lang="en">Code assigned to a specific production run for traceability.</skos:definition>
        <skos:example xml:lang="en">Batch 2023-10-A-X55.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000021 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000021">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:label xml:lang="en">business partner number</rdfs:label>
        <skos:definition xml:lang="en">Unique identifier for a legal entity in the automotive supply chain network (Catena-X standard).</skos:definition>
        <skos:example xml:lang="en">BPNL00000003AY2 (Example BPN).</skos:example>
        <co:PMD_0050117>BPN</co:PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000022 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000022">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000848"/>
        <rdfs:comment xml:lang="en">Indicates ductility. Low strain at break (less than 5%) suggests brittle behavior.</rdfs:comment>
        <rdfs:label xml:lang="en">strain at break</rdfs:label>
        <skos:definition xml:lang="en">The elongation of a specimen at the moment of rupture, expressed as a percentage of the original gauge length.</skos:definition>
        <skos:example xml:lang="en">3% strain at break for a glass-filled polyamide.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000023 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000023">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:comment xml:lang="en">Critical for injection molding simulations to predict mold filling.</rdfs:comment>
        <rdfs:label xml:lang="en">viscosity</rdfs:label>
        <skos:definition xml:lang="en">A measure of a fluid&apos;s resistance to flow.</skos:definition>
        <skos:example xml:lang="en">The melt viscosity of polypropylene at 230°C.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000025 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000025">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:comment xml:lang="en">Polymers are non-Newtonian; their shear viscosity decreases as shear rate increases (shear thinning).</rdfs:comment>
        <rdfs:label xml:lang="en">shear viscosity</rdfs:label>
        <skos:definition xml:lang="en">The viscosity of a fluid when subjected to shear stress; defined as the ratio of shear stress to shear rate.</skos:definition>
        <skos:example xml:lang="en">Viscosity curve data required for Moldflow simulation.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000026 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000026">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000882"/>
        <rdfs:comment xml:lang="en">Below Tg, the amorphous phase is frozen; above Tg, polymer chains have mobility.</rdfs:comment>
        <rdfs:label xml:lang="en">glass transition temperature</rdfs:label>
        <skos:definition xml:lang="en">The temperature range where a polymer material transitions from a hard, glassy material to a soft, rubbery material.</skos:definition>
        <skos:example xml:lang="en">Tg of approx. 50°C for dry PA66.</skos:example>
        <co:PMD_0050117>Tg</co:PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000027 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000027">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000981"/>
        <rdfs:comment xml:lang="en">Crucial for calculating gap and flush in automotive assembly where different materials (steel vs plastic) meet.</rdfs:comment>
        <rdfs:label xml:lang="en">coefficient of linear thermal expansion</rdfs:label>
        <skos:definition xml:lang="en">The fractional change in length per degree of temperature change.</skos:definition>
        <skos:example xml:lang="en">CLTE is distinct in flow-direction vs cross-flow direction for fiber reinforced parts.</skos:example>
        <co:PMD_0050117>CLTE</co:PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000028 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000028">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000981"/>
        <rdfs:comment xml:lang="en">Used to calculate cooling times in injection molding.</rdfs:comment>
        <rdfs:label xml:lang="en">specific heat capacity</rdfs:label>
        <skos:definition xml:lang="en">The amount of heat energy required to raise the temperature of a substance per unit of mass.</skos:definition>
        <skos:example xml:lang="en">1700 J/(kg·K) for Polypropylene.</skos:example>
        <co:PMD_0050117>Cp</co:PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000029 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000029">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000952"/>
        <rdfs:comment xml:lang="en">Often measured via Charpy or Izod notched impact tests.</rdfs:comment>
        <rdfs:label xml:lang="en">impact strength</rdfs:label>
        <skos:definition xml:lang="en">The ability of a material to absorb energy and resist fracture under high speed loading.</skos:definition>
        <skos:example xml:lang="en">High impact strength is required for bumper beams.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000030 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000030">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000949"/>
        <rdfs:comment xml:lang="en">Standard metric for stiffness in plastics (ISO 178).</rdfs:comment>
        <rdfs:label xml:lang="en">flexural modulus</rdfs:label>
        <skos:definition xml:lang="en">The ratio of stress to strain in flexural deformation, or the tendency for a material to resist bending.</skos:definition>
        <skos:example xml:lang="en">Flexural modulus of 8500 MPa for PA66-GF30.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000031 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000031">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000952"/>
        <rdfs:comment xml:lang="en">Relevant for snap-fit joints in automotive interiors.</rdfs:comment>
        <rdfs:label xml:lang="en">flexural strength</rdfs:label>
        <skos:definition xml:lang="en">The maximum stress a material can withstand in bending before yielding or breaking.</skos:definition>
        <skos:example xml:lang="en">250 MPa for a high-performance composite.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0000032 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0000032">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:comment xml:lang="en">Crucial for PA66 as it absorbs moisture, changing its mechanical properties (conditioning).</rdfs:comment>
        <rdfs:label xml:lang="en">humidity</rdfs:label>
        <skos:definition xml:lang="en">The concentration of water vapor present in the air or environment surrounding a material.</skos:definition>
        <skos:example xml:lang="en">50% Relative Humidity (standard conditioning atmosphere).</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010000 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010000">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:comment xml:lang="en">Whether a material is raw material depends on its participation in a particular production or recycling workflow.</rdfs:comment>
        <rdfs:label xml:lang="en">raw material</rdfs:label>
        <skos:definition xml:lang="en">A material entity that is intended to be consumed, transformed, or incorporated as input in a manufacturing, recycling, or material processing process.</skos:definition>
        <skos:example xml:lang="en">PA66 pellets supplied to an injection molding process as input material.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010001 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010001">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000002"/>
        <rdfs:comment xml:lang="en">This class represents the additive material itself; the context-dependent function is represented by additive role.</rdfs:comment>
        <rdfs:label xml:lang="en">additive</rdfs:label>
        <skos:definition xml:lang="en">An engineered material intentionally incorporated in a base material in a comparatively small amount to modify processing behavior, performance properties, appearance, or cost.</skos:definition>
        <skos:example xml:lang="en">A UV stabilizer added to an exterior polymer trim material.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010002 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010002">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000002"/>
        <rdfs:comment xml:lang="en">The corresponding realizable entity is PMD Core matrix role; this class is used for material entities considered as the continuous phase of a composite.</rdfs:comment>
        <rdfs:label xml:lang="en">matrix</rdfs:label>
        <skos:definition xml:lang="en">An engineered material that forms the continuous phase of a composite material and binds or embeds reinforcement, filler, or dispersed material constituents.</skos:definition>
        <skos:example xml:lang="en">The PA66 phase in a PA66-GF25 composite.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010003 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010003">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:comment xml:lang="en">Values are normally reported for specified test conditions, such as ISO 62 or a specified conditioning atmosphere.</rdfs:comment>
        <rdfs:label xml:lang="en">water absorption</rdfs:label>
        <skos:definition xml:lang="en">A disposition of a material to take up water from a liquid water or humid environment under specified exposure conditions.</skos:definition>
        <skos:example xml:lang="en">The percentage mass increase of a polyamide specimen after immersion in water.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010004 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010004">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:label xml:lang="en">materials information</rdfs:label>
        <skos:definition xml:lang="en">An information content entity that specifies material-related characteristics of a product, component, material batch, or material grade.</skos:definition>
        <skos:example xml:lang="en">A data record listing material designation, density, fiber content, and recycled content for an automotive component.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010005 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010005">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0025001"/>
        <rdfs:label xml:lang="en">material composition</rdfs:label>
        <skos:definition xml:lang="en">A composition that describes the material constituents and constituent amounts of a product, component, material batch, or material grade.</skos:definition>
        <skos:example xml:lang="en">A composition stating that PA66-GF25 contains a PA66 matrix and nominally 25 percent glass fiber by mass.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010006 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010006">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:comment xml:lang="en">This class covers material entities whose origin is a recycling process; the amount or share of recycled content should be represented separately.</rdfs:comment>
        <rdfs:label xml:lang="en">recycled material</rdfs:label>
        <skos:definition xml:lang="en">A material entity that has been recovered from waste, discarded products, by-products, or production residues through a recycling process for subsequent use.</skos:definition>
        <skos:example xml:lang="en">Regranulated polypropylene produced from end-of-life vehicle parts.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010007 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010007">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:comment xml:lang="en">Use for the origin state of a material; use recycled material share for quantities or proportions.</rdfs:comment>
        <rdfs:label xml:lang="en">recycled</rdfs:label>
        <skos:definition xml:lang="en">A quality of a material entity indicating that the material has an origin in a recycling process rather than only in primary material production.</skos:definition>
        <skos:example xml:lang="en">A recycled quality borne by a polymer regrind used in a new injection molding batch.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010020 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010020">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
        <rdfs:label xml:lang="en">product footprint</rdfs:label>
        <skos:definition xml:lang="en">A realizable entity representing the environmental, carbon, material, or resource footprint associated with a product over a stated scope.</skos:definition>
        <skos:example xml:lang="en">A product footprint report for an alternator covering cradle-to-gate carbon emissions and recycled material content.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010021 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010021">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
        <rdfs:comment xml:lang="en">The glossary spelling &apos;recylced material share&apos; was normalized to &apos;recycled material share&apos;.</rdfs:comment>
        <rdfs:label xml:lang="en">recycled material share</rdfs:label>
        <skos:definition xml:lang="en">A relational quality that relates a material, component, or product to the proportion of its material content that originates from recycled sources.</skos:definition>
        <skos:example xml:lang="en">A bumper fascia with 30 percent recycled polypropylene content.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010022 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010022">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0010020"/>
        <rdfs:label xml:lang="en">product carbon footprint</rdfs:label>
        <skos:definition xml:lang="en">A product footprint that reports greenhouse gas emissions associated with a product over a stated lifecycle scope.</skos:definition>
        <skos:example xml:lang="en">A product carbon footprint in kg CO2 equivalent for one steering system.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010023 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010023">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000008"/>
        <rdfs:label xml:lang="en">process footprint</rdfs:label>
        <skos:definition xml:lang="en">A process attribute that quantifies environmental burden associated with executing a process under specified boundary conditions.</skos:definition>
        <skos:example xml:lang="en">Electricity consumption and associated emissions for one injection molding cycle.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010024 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010024">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0010023"/>
        <rdfs:label xml:lang="en">process carbon footprint</rdfs:label>
        <skos:definition xml:lang="en">A process footprint that quantifies greenhouse gas emissions associated with executing a process.</skos:definition>
        <skos:example xml:lang="en">The carbon footprint of recycling one kilogram of PA66-GF25 scrap.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010025 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010025">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020143"/>
        <rdfs:label xml:lang="en">lifecycle</rdfs:label>
        <skos:definition xml:lang="en">A process chain that comprises the stages through which a product or material passes from raw material acquisition through production, use, and end-of-life treatment.</skos:definition>
        <skos:example xml:lang="en">The lifecycle of an automotive control unit from material extraction to recycling.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010026 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010026">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">lifecycle stage</rdfs:label>
        <skos:definition xml:lang="en">A process that is a distinguishable part of a product or material lifecycle.</skos:definition>
        <skos:example xml:lang="en">Main product production as a lifecycle stage for an automotive component.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010027 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010027">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0010026"/>
        <rdfs:comment xml:lang="en">The glossary spelling &apos;raw material acquistion&apos; was normalized to &apos;raw material acquisition&apos;.</rdfs:comment>
        <rdfs:label xml:lang="en">raw material acquisition</rdfs:label>
        <skos:definition xml:lang="en">A lifecycle stage in which natural resources, secondary materials, or basic feedstocks are obtained and prepared for production.</skos:definition>
        <skos:example xml:lang="en">Obtaining recycled polymer regranulate for later component production.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010028 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010028">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0010026"/>
        <rdfs:label xml:lang="en">main product production</rdfs:label>
        <skos:definition xml:lang="en">A lifecycle stage in which raw materials, intermediate products, or components are transformed into the main product.</skos:definition>
        <skos:example xml:lang="en">Injection molding and assembly steps used to produce an automotive housing.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010029 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010029">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0010026"/>
        <rdfs:label xml:lang="en">distribution</rdfs:label>
        <skos:definition xml:lang="en">A lifecycle stage in which products, components, or materials are transported, stored, or transferred between supply chain actors.</skos:definition>
        <skos:example xml:lang="en">Shipment of remanufactured components from a supplier to a vehicle manufacturer.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010030 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010030">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0010026"/>
        <rdfs:label xml:lang="en">end of life</rdfs:label>
        <skos:definition xml:lang="en">A lifecycle stage in which a product or component has reached the end of its intended use and is directed to reuse, remanufacturing, recycling, recovery, or disposal.</skos:definition>
        <skos:example xml:lang="en">Removal of a component from an end-of-life vehicle for circular value assessment.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010031 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010031">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0010026"/>
        <rdfs:label xml:lang="en">recycling lifecycle stage</rdfs:label>
        <skos:definition xml:lang="en">A lifecycle stage in which used materials or products are processed to recover material for further use.</skos:definition>
        <skos:example xml:lang="en">Grinding, sorting, and regranulating a polymer component after dismantling.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010033 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010033">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0010022"/>
        <rdfs:label xml:lang="en">carbon footprint amount in recycling</rdfs:label>
        <skos:definition xml:lang="en">A carbon footprint amount calculated for a recycling scenario.</skos:definition>
        <skos:example xml:lang="en">The kg CO2 equivalent attributed to recycling a dismantled component.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010034 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010034">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0010022"/>
        <rdfs:label xml:lang="en">carbon footprint amount in remanufacturing</rdfs:label>
        <skos:definition xml:lang="en">A carbon footprint amount calculated for a remanufacturing scenario.</skos:definition>
        <skos:example xml:lang="en">The kg CO2 equivalent attributed to inspecting, repairing, and remanufacturing a component.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010035 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010035">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0010022"/>
        <rdfs:label xml:lang="en">carbon footprint amount in reuse</rdfs:label>
        <skos:definition xml:lang="en">A carbon footprint amount calculated for a reuse scenario.</skos:definition>
        <skos:example xml:lang="en">The kg CO2 equivalent attributed to checking and reusing a component without remanufacturing.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010036 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010036">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0010022"/>
        <rdfs:label xml:lang="en">carbon footprint amount in new production</rdfs:label>
        <skos:definition xml:lang="en">A carbon footprint amount calculated for a new production scenario.</skos:definition>
        <skos:example xml:lang="en">The kg CO2 equivalent attributed to manufacturing a replacement component from primary material.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010040 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010040">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:label xml:lang="en">humidity absorption</rdfs:label>
        <skos:definition xml:lang="en">A disposition of a material or component to absorb water vapor from a humid environment under specified exposure conditions.</skos:definition>
        <skos:example xml:lang="en">Moisture uptake by a PA66 component during use at 50 percent relative humidity.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010050 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010050">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
        <rdfs:label xml:lang="en">remaining lifetime</rdfs:label>
        <skos:definition xml:lang="en">A realizable entity representing the usable lifetime expected to remain for a product or component before it no longer satisfies its intended function or circular value criteria.</skos:definition>
        <skos:example xml:lang="en">An alternator estimated to have 24 months of usable service life remaining after inspection.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010051 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010051">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
        <rdfs:label xml:lang="en">actual lifetime</rdfs:label>
        <skos:definition xml:lang="en">A realizable entity representing the observed elapsed lifetime of a product or component up to a stated lifecycle event.</skos:definition>
        <skos:example xml:lang="en">The time between first vehicle registration and dismantling of a component.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010052 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010052">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:comment xml:lang="en">The glossary spelling &apos;Non-destructive Distmantlability&apos; was normalized to &apos;non-destructive dismantlability&apos;.</rdfs:comment>
        <rdfs:label xml:lang="en">non-destructive dismantlability</rdfs:label>
        <skos:definition xml:lang="en">A disposition of a product or component to be dismantled without destroying the product, component, or material portions that are intended for later use.</skos:definition>
        <skos:example xml:lang="en">A clipped interior trim part that can be removed intact for reuse.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010053 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010053">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000033"/>
        <rdfs:label xml:lang="en">safety information</rdfs:label>
        <skos:definition xml:lang="en">A directive information entity that specifies safety-relevant instructions, warnings, or constraints for handling, dismantling, treating, transporting, or reusing a product or component.</skos:definition>
        <skos:example xml:lang="en">A warning to disconnect a high-voltage battery before dismantling a component.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010054 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010054">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">recycling</rdfs:label>
        <skos:definition xml:lang="en">A process in which used materials, components, or products are collected and processed to recover material for further use.</skos:definition>
        <skos:example xml:lang="en">Sorting and regranulating polymer parts from an end-of-life vehicle.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010055 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010055">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">dismantling</rdfs:label>
        <skos:definition xml:lang="en">A process in which a product or component is taken apart so that parts, materials, or information can be recovered, assessed, reused, repaired, remanufactured, recycled, or disposed.</skos:definition>
        <skos:example xml:lang="en">Removing a vehicle door module from an end-of-life vehicle before quality assessment.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010056 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010056">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000104"/>
        <rdfs:label xml:lang="en">dismantling guideline for recycling</rdfs:label>
        <skos:definition xml:lang="en">A plan specification that provides instructions for dismantling a product or component so that materials can be routed to appropriate recycling treatment.</skos:definition>
        <skos:example xml:lang="en">A guideline specifying how to separate a polymer housing from attached metal inserts before recycling.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010057 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010057">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:label xml:lang="en">recycling material quality</rdfs:label>
        <skos:definition xml:lang="en">A disposition of a product or material to be recycled while preserving a specified level of material quality.</skos:definition>
        <skos:example xml:lang="en">A polymer component designed so that the recovered polymer remains suitable for automotive applications.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010058 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010058">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:label xml:lang="en">recycling availability</rdfs:label>
        <skos:definition xml:lang="en">A disposition of a product, component, or material to be practically available for recycling in a technical cycle.</skos:definition>
        <skos:example xml:lang="en">A component whose material can be separated and accepted by an established recycling route.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010059 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010059">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000104"/>
        <rdfs:label xml:lang="en">dismantling instructions</rdfs:label>
        <skos:definition xml:lang="en">A plan specification that describes the actions, order, tools, and constraints for safely and correctly dismantling a product or component.</skos:definition>
        <skos:example xml:lang="en">Stepwise instructions for removing a battery module from a vehicle.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010060 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010060">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:label xml:lang="en">dismantlability</rdfs:label>
        <skos:definition xml:lang="en">A disposition of a product or component to be dismantled under stated technical, safety, time, and damage constraints.</skos:definition>
        <skos:example xml:lang="en">A bolted assembly has higher dismantlability than an inseparably bonded assembly when reuse is intended.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010061 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010061">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
        <rdfs:label xml:lang="en">average dismantling time</rdfs:label>
        <skos:definition xml:lang="en">A realizable entity representing the estimated average time required to dismantle a product or component under specified conditions.</skos:definition>
        <skos:example xml:lang="en">An average dismantling time of 12 minutes for removal of a door module.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010062 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010062">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">treatment technique</rdfs:label>
        <skos:definition xml:lang="en">A process used to treat a dismantled component, product, or material after removal from its original assembly.</skos:definition>
        <skos:example xml:lang="en">Mechanical shredding, cleaning, or material separation applied after dismantling.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010063 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010063">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:label xml:lang="en">best treatment techniques</rdfs:label>
        <skos:definition xml:lang="en">An information content entity that recommends preferred treatment techniques for a dismantled product, component, or material in a given circular economy scenario.</skos:definition>
        <skos:example xml:lang="en">A recommendation to remove electronics before shredding a polymer-rich component.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010064 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010064">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000010"/>
        <rdfs:label xml:lang="en">disassembly software</rdfs:label>
        <skos:definition xml:lang="en">Software used to support, guide, document, or validate the disassembly or dismantling of a product or component.</skos:definition>
        <skos:example xml:lang="en">A workshop application that displays product-specific disassembly instructions.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010065 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010065">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="en">disassembly tool</rdfs:label>
        <skos:definition xml:lang="en">A device used to carry out a disassembly or dismantling operation on a product or component.</skos:definition>
        <skos:example xml:lang="en">A puller tool used to remove a clipped trim component without damage.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010066 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010066">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000104"/>
        <rdfs:label xml:lang="en">fastening technique</rdfs:label>
        <skos:definition xml:lang="en">A plan specification that describes how parts are joined, fixed, or released in an assembly.</skos:definition>
        <skos:example xml:lang="en">A specification that a housing is fastened with Torx screws and snap-fit clips.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010067 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010067">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000104"/>
        <rdfs:label xml:lang="en">dismantling sequence</rdfs:label>
        <skos:definition xml:lang="en">A plan specification that orders the steps required to dismantle a product or component.</skos:definition>
        <skos:example xml:lang="en">Remove cover, disconnect cable, release clips, and lift out module.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010068 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010068">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000310"/>
        <rdfs:label xml:lang="en">exploding diagram</rdfs:label>
        <skos:definition xml:lang="en">A document or figure that depicts a product or assembly with parts spatially separated to show their relative positions and dismantling relationships.</skos:definition>
        <skos:example xml:lang="en">An exploded-view diagram showing screws, clips, housing shells, and subcomponents of a control unit.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010069 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010069">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:label xml:lang="en">sub-group name</rdfs:label>
        <skos:definition xml:lang="en">An identifier that records the name of a material sub-group in a material classification scheme.</skos:definition>
        <skos:example xml:lang="en">The VDA 231-106 sub-group name &apos;cast aluminium alloys&apos;.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010070 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010070">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:label xml:lang="en">sub-group identifier</rdfs:label>
        <skos:definition xml:lang="en">An identifier that records the code or number of a material sub-group in a material classification scheme.</skos:definition>
        <skos:example xml:lang="en">The VDA 231-106 sub-group code &apos;2.1.1&apos;.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010071 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010071">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:label xml:lang="en">main group name</rdfs:label>
        <skos:definition xml:lang="en">An identifier that records the name of a material main group in a material classification scheme.</skos:definition>
        <skos:example xml:lang="en">The VDA 231-106 main group name &apos;polymer materials&apos;.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010072 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010072">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:label xml:lang="en">main group identifier</rdfs:label>
        <skos:definition xml:lang="en">An identifier that records the code or number of a material main group in a material classification scheme.</skos:definition>
        <skos:example xml:lang="en">The VDA 231-106 main group code &apos;5&apos;.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010073 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010073">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">reuse</rdfs:label>
        <skos:definition xml:lang="en">A process in which a discarded or removed product or component is used again while retaining its original function.</skos:definition>
        <skos:example xml:lang="en">A dismantled and inspected body control module installed in another vehicle.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010074 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010074">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:label xml:lang="en">product quality</rdfs:label>
        <skos:definition xml:lang="en">A disposition of a product or component to satisfy requirements for an intended circular economy route, based on relevant condition, completeness, functional, and standard-based criteria.</skos:definition>
        <skos:example xml:lang="en">A reused body part assigned a quality class after inspection for dents, corrosion, paint damage, and completeness.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010075 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010075">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:label xml:lang="en">necessary test protocols equipment</rdfs:label>
        <skos:definition xml:lang="en">A disposition of a product or component to require specific test protocols or uncommon equipment before it can be accepted for reuse, repair, remanufacturing, or recycling.</skos:definition>
        <skos:example xml:lang="en">A high-voltage component requiring insulation resistance testing before reuse.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010076 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010076">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:label xml:lang="en">reusability</rdfs:label>
        <skos:definition xml:lang="en">A disposition of a product or component to be reused in its original function under stated technical, legal, safety, and quality constraints.</skos:definition>
        <skos:example xml:lang="en">A complete undamaged headlamp assembly that can be installed as a replacement part.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010077 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010077">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">quality body parts</rdfs:label>
        <skos:definition xml:lang="en">A quality of a body part component that characterizes its externally relevant condition, such as paint damage, dents, corrosion, and component-specific defects.</skos:definition>
        <skos:example xml:lang="en">A door panel quality assessment based on dents and paint scratches.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010078 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010078">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">quality grade</rdfs:label>
        <skos:definition xml:lang="en">A quality that records the grade assigned to a product or component according to a stated quality standard or assessment scheme.</skos:definition>
        <skos:example xml:lang="en">A, B, or C quality grade assigned to a used car part.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010079 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010079">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">completeness</rdfs:label>
        <skos:definition xml:lang="en">A quality of a product or component indicating whether required subcomponents, fasteners, interfaces, or accessories are present.</skos:definition>
        <skos:example xml:lang="en">A mirror assembly assessed as complete because housing, glass, wiring, and mounting clips are present.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010080 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010080">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000104"/>
        <rdfs:label xml:lang="en">used quality standard</rdfs:label>
        <skos:definition xml:lang="en">A plan specification that defines the quality assessment criteria applied to a reused, repaired, remanufactured, or recycled product or component.</skos:definition>
        <skos:example xml:lang="en">VDI 4080 used as the assessment standard for reuse quality.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010081 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010081">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">mounting point integrity</rdfs:label>
        <skos:definition xml:lang="en">A quality of a product or component indicating whether its mounting points, clips, tabs, or attachment features are intact and functional.</skos:definition>
        <skos:example xml:lang="en">A bumper bracket with all mounting tabs undamaged.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010082 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010082">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">surface cleanliness</rdfs:label>
        <skos:definition xml:lang="en">A quality of a product, component, or material surface indicating the degree to which it is free from oil, dust, residues, and other contaminants.</skos:definition>
        <skos:example xml:lang="en">A cleaned polymer surface acceptable for adhesive bonding during reuse preparation.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010083 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010083">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">repair time</rdfs:label>
        <skos:definition xml:lang="en">A temporal quality that estimates or records the time required to repair a specified damage or defect on a product or component.</skos:definition>
        <skos:example xml:lang="en">The time needed to repair a paint scratch and small dent on a door panel.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010084 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010084">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">crack count</rdfs:label>
        <skos:definition xml:lang="en">A quality that records the number of cracks observed on a product, component, coating, or material surface.</skos:definition>
        <skos:example xml:lang="en">Two cracks recorded in the paint layer during dismantling inspection.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010085 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010085">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">dent damage</rdfs:label>
        <skos:definition xml:lang="en">A quality of a sheet metal or body component indicating the presence or extent of dents or deformations that impair the component shape.</skos:definition>
        <skos:example xml:lang="en">A quarter panel with two visible dents after vehicle use.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010086 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010086">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">damage area</rdfs:label>
        <skos:definition xml:lang="en">A quality that quantifies the surface area of visible damage on a product, component, coating, or material surface.</skos:definition>
        <skos:example xml:lang="en">A paint damage area of 50 square centimeters on a door panel.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010087 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010087">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">paint damage</rdfs:label>
        <skos:definition xml:lang="en">A quality of a painted product or component indicating damage to the paintwork, such as scratches, chips, cracks, or coating loss.</skos:definition>
        <skos:example xml:lang="en">Stone-chip damage on a painted bumper cover.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010088 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010088">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:label xml:lang="en">vehicle identification number</rdfs:label>
        <skos:definition xml:lang="en">An identifier assigned to a vehicle according to a vehicle identification number scheme and used to identify the individual vehicle.</skos:definition>
        <skos:example xml:lang="en">A 17-character VIN read from a vehicle during dismantling intake.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010090 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010090">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:label xml:lang="en">manufacturer name</rdfs:label>
        <skos:definition xml:lang="en">An identifier that records the name by which a manufacturer is referred to in a data exchange, contract, product record, or manufacturer system.</skos:definition>
        <skos:example xml:lang="en">The manufacturer name &apos;Schaeffler&apos; in a supplier record.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010091 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010091">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000029"/>
        <rdfs:label xml:lang="en">manufacturer plant site</rdfs:label>
        <skos:definition xml:lang="en">A site at which a manufacturer carries out production, assembly, treatment, storage, or related industrial operations.</skos:definition>
        <skos:example xml:lang="en">A specific plant where a material batch or component was produced.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010092 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010092">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0000021"/>
        <rdfs:comment xml:lang="en">This is modeled as a Catena-X-specific subtype of the existing business partner number class.</rdfs:comment>
        <rdfs:label xml:lang="en">CX business partner number</rdfs:label>
        <skos:definition xml:lang="en">A business partner number used in Catena-X to identify a legal entity, site, or address participating in automotive data exchange.</skos:definition>
        <skos:example xml:lang="en">A Catena-X BPNL identifier for a supplier legal entity.</skos:example>
        <co:PMD_0050117>BPN</co:PMD_0050117>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010093 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010093">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:label xml:lang="en">VIN</rdfs:label>
        <skos:definition xml:lang="en">An identifier assigned to an individual vehicle according to a vehicle identification number scheme.</skos:definition>
        <skos:example xml:lang="en">A 17-character vehicle identification number used in a dismantling record.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010094 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010094">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:label xml:lang="en">vehicle model</rdfs:label>
        <skos:definition xml:lang="en">An identifier that records the model designation of a vehicle type as defined by a manufacturer.</skos:definition>
        <skos:example xml:lang="en">A manufacturer-specific vehicle model name used in a product data record.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010095 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010095">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:label xml:lang="en">component information</rdfs:label>
        <skos:definition xml:lang="en">An information content entity that aggregates identifiers, specifications, usage data, condition data, or circular economy information about a component.</skos:definition>
        <skos:example xml:lang="en">A component record containing part number, material designation, mileage, and reuse assessment.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010096 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010096">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">mileage of the component</rdfs:label>
        <skos:definition xml:lang="en">A quality that quantifies the travel distance accumulated by a component during use in a vehicle.</skos:definition>
        <skos:example xml:lang="en">A used alternator recorded with 125000 km of component mileage.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010097 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010097">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">component age</rdfs:label>
        <skos:definition xml:lang="en">A temporal quality that quantifies elapsed time since a component was produced, commissioned, installed, or first used, according to a stated reference event.</skos:definition>
        <skos:example xml:lang="en">A component age of six years measured from vehicle production date to dismantling date.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010098 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010098">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0001933"/>
        <rdfs:label xml:lang="en">year of construction</rdfs:label>
        <skos:definition xml:lang="en">A date value specification that records the calendar year in which a product, component, vehicle, or facility was constructed or manufactured.</skos:definition>
        <skos:example xml:lang="en">The year 2019 recorded as the construction year of a vehicle.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010100 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010100">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">environmental condition</rdfs:label>
        <skos:definition xml:lang="en">A quality of an environment that is relevant to material behavior, processing, testing, storage, use, or degradation.</skos:definition>
        <skos:example xml:lang="en">A conditioning atmosphere with specified temperature and relative humidity.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010101 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010101">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000002"/>
        <rdfs:comment xml:lang="en">The role borne by such a material in a composite is PMD Core filler role.</rdfs:comment>
        <rdfs:label xml:lang="en">filler</rdfs:label>
        <skos:definition xml:lang="en">An engineered material incorporated in another material to occupy volume, modify properties, reduce cost, or contribute reinforcement in a composite or compound.</skos:definition>
        <skos:example xml:lang="en">Glass fibers or mineral particles added to a polymer compound.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010102 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010102">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0010101"/>
        <rdfs:comment xml:lang="en">The Excel hint to PMD Core filler role was modeled as a material class here because the glossary term names the reinforcing material, not only the role.</rdfs:comment>
        <rdfs:label xml:lang="en">reinforcement</rdfs:label>
        <skos:definition xml:lang="en">A filler material that is incorporated into a matrix material to improve load-bearing, stiffness, strength, impact, or dimensional performance.</skos:definition>
        <skos:example xml:lang="en">Chopped glass fiber used as reinforcement in PA66-GF25.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010103 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010103">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
        <rdfs:label xml:lang="en">further content</rdfs:label>
        <skos:definition xml:lang="en">A composition data item that records additional material constituents or content fractions not captured by the primary material composition fields.</skos:definition>
        <skos:example xml:lang="en">A data item recording minor additive content in a polymer compound.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010104 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010104">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020102"/>
        <rdfs:comment xml:lang="en">The Excel source references ISO 15512 for plastics water content measurement.</rdfs:comment>
        <rdfs:label xml:lang="en">water content</rdfs:label>
        <skos:definition xml:lang="en">A mass proportion that quantifies the amount of water contained in a material under specified measurement or conditioning conditions.</skos:definition>
        <skos:example xml:lang="en">Water content of a polyamide granulate measured before injection molding.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010105 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010105">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020102"/>
        <rdfs:comment xml:lang="en">The Excel source references ISO 3451 for ash content, often used to estimate inorganic filler content.</rdfs:comment>
        <rdfs:label xml:lang="en">ash content</rdfs:label>
        <skos:definition xml:lang="en">A mass proportion that quantifies the inorganic residue remaining after controlled combustion or calcination of a material sample.</skos:definition>
        <skos:example xml:lang="en">Ash content used to estimate glass fiber or mineral filler content in a polymer compound.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010106 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010106">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:label xml:lang="en">material class</rdfs:label>
        <skos:definition xml:lang="en">An information content entity that assigns a material, component, or product to a material category in a stated classification scheme.</skos:definition>
        <skos:example xml:lang="en">A VDA 231-106 material class assignment for polymer materials.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010107 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010107">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:label xml:lang="en">material abbreviation</rdfs:label>
        <skos:definition xml:lang="en">An identifier that records a short material designation or abbreviation used for a material or material family.</skos:definition>
        <skos:example xml:lang="en">PA66-GF25 as an abbreviated designation for a glass-fiber-reinforced polyamide 66 compound.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010108 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010108">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000933"/>
        <rdfs:label xml:lang="en">manufacturing simulation</rdfs:label>
        <skos:definition xml:lang="en">A simulation process that represents a manufacturing process and its material, process, geometry, or performance consequences.</skos:definition>
        <skos:example xml:lang="en">A simulation of an injection molding process used to predict filling and cooling behavior.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010109 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010109">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0010108"/>
        <rdfs:label xml:lang="en">injection molding simulation</rdfs:label>
        <skos:definition xml:lang="en">A manufacturing simulation that represents an injection molding process, including relevant material, mold, filling, packing, cooling, or warpage behavior.</skos:definition>
        <skos:example xml:lang="en">A mold-filling simulation for a PA66-GF25 housing.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010110 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010110">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000933"/>
        <rdfs:label xml:lang="en">quasistatic simulation</rdfs:label>
        <skos:definition xml:lang="en">A simulation process that represents material or component response under loading conditions where inertial effects are negligible.</skos:definition>
        <skos:example xml:lang="en">A quasistatic finite element simulation of a bracket under service load.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010111 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010111">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000933"/>
        <rdfs:label xml:lang="en">thermal simulation</rdfs:label>
        <skos:definition xml:lang="en">A simulation process that represents heat transfer, temperature distribution, or thermally induced material behavior.</skos:definition>
        <skos:example xml:lang="en">A cooling simulation for an injection molded component.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010112 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010112">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000952"/>
        <rdfs:label xml:lang="en">quasistatic stress normal</rdfs:label>
        <skos:definition xml:lang="en">A strength-related material or simulation output quality that represents stress normal to a reference direction under quasistatic loading.</skos:definition>
        <skos:example xml:lang="en">Normal stress predicted by a quasistatic simulation perpendicular to fiber orientation.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010113 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010113">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000952"/>
        <rdfs:label xml:lang="en">quasistatic stress parallel</rdfs:label>
        <skos:definition xml:lang="en">A strength-related material or simulation output quality that represents stress parallel to a reference direction under quasistatic loading.</skos:definition>
        <skos:example xml:lang="en">Stress predicted parallel to fiber orientation in a quasistatic simulation.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010114 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010114">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000848"/>
        <rdfs:label xml:lang="en">quasistatic strain normal</rdfs:label>
        <skos:definition xml:lang="en">A mechanical property or simulation output quality that represents strain normal to a reference direction under quasistatic loading.</skos:definition>
        <skos:example xml:lang="en">Normal strain predicted perpendicular to fiber orientation in a quasistatic simulation.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010115 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010115">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000848"/>
        <rdfs:label xml:lang="en">quasistatic strain parallel</rdfs:label>
        <skos:definition xml:lang="en">A mechanical property or simulation output quality that represents strain parallel to a reference direction under quasistatic loading.</skos:definition>
        <skos:example xml:lang="en">Strain predicted parallel to fiber orientation in a quasistatic simulation.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010116 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010116">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0040001"/>
        <rdfs:label xml:lang="en">elongation expansion normal</rdfs:label>
        <skos:definition xml:lang="en">A length-related quality or simulation output that represents elongation or expansion normal to a reference direction.</skos:definition>
        <skos:example xml:lang="en">Thermal expansion normal to fiber orientation in a molded composite.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010117 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010117">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0040001"/>
        <rdfs:label xml:lang="en">elongation expansion parallel</rdfs:label>
        <skos:definition xml:lang="en">A length-related quality or simulation output that represents elongation or expansion parallel to a reference direction.</skos:definition>
        <skos:example xml:lang="en">Thermal expansion parallel to fiber orientation in a molded composite.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010118 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010118">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0040001"/>
        <rdfs:label xml:lang="en">length of fibers</rdfs:label>
        <skos:definition xml:lang="en">A length quality that quantifies the characteristic or measured length of fibers in a fiber-containing material.</skos:definition>
        <skos:example xml:lang="en">Mean glass fiber length after injection molding of PA66-GF25.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010119 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010119">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020102"/>
        <rdfs:label xml:lang="en">reutilization material share</rdfs:label>
        <skos:definition xml:lang="en">A mass proportion that quantifies the share of material from rework, regrind, or scrap that is reused within the process or production system that generated it.</skos:definition>
        <skos:example xml:lang="en">The percentage of in-process regrind returned to an injection molding feedstock.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010120 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010120">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:label xml:lang="en">origin</rdfs:label>
        <skos:definition xml:lang="en">An information content entity that records the source category, provenance, or supply-chain origin of a material.</skos:definition>
        <skos:example xml:lang="en">An origin statement that a polymer fraction is post-consumer automotive recycled material.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010121 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010121">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020102"/>
        <rdfs:label xml:lang="en">pre-consumer material share</rdfs:label>
        <skos:definition xml:lang="en">A mass proportion that quantifies material content originating from pre-consumer production residues, by-products, rework, or scrap.</skos:definition>
        <skos:example xml:lang="en">The share of molding scrap reused before the product reached a consumer.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010122 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010122">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020102"/>
        <rdfs:label xml:lang="en">post-consumer material share</rdfs:label>
        <skos:definition xml:lang="en">A mass proportion that quantifies material content originating from products or materials recovered after consumer or user service.</skos:definition>
        <skos:example xml:lang="en">The share of polypropylene recovered from end-of-life vehicle parts.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010123 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010123">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020102"/>
        <rdfs:label xml:lang="en">material source share</rdfs:label>
        <skos:definition xml:lang="en">A mass proportion that quantifies the share of material from a stated source category, such as primary, secondary, pre-consumer, post-consumer, automotive, or non-automotive sources.</skos:definition>
        <skos:example xml:lang="en">A material source share for secondary automotive recycled content.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010124 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010124">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000310"/>
        <rdfs:label xml:lang="en">other recycling information</rdfs:label>
        <skos:definition xml:lang="en">A document or information content entity that provides additional evidence, provenance, compliance, or quality information about material origin or recycling.</skos:definition>
        <skos:example xml:lang="en">A supplier declaration documenting recycled material origin and quality.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010125 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010125">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020102"/>
        <rdfs:label xml:lang="en">automotive material share</rdfs:label>
        <skos:definition xml:lang="en">A mass proportion that quantifies the share of material content originating from automotive sources.</skos:definition>
        <skos:example xml:lang="en">The fraction of recycled polymer sourced from end-of-life vehicle components.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010126 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010126">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020102"/>
        <rdfs:label xml:lang="en">non-automotive material share</rdfs:label>
        <skos:definition xml:lang="en">A mass proportion that quantifies the share of material content originating from non-automotive sources.</skos:definition>
        <skos:example xml:lang="en">The fraction of recycled polymer sourced from consumer packaging rather than vehicle components.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010127 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010127">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:label xml:lang="en">secondary material</rdfs:label>
        <skos:definition xml:lang="en">A material entity obtained from waste, by-products, production residues, or recovered products and intended to substitute for primary material in a production process.</skos:definition>
        <skos:example xml:lang="en">A recycled polymer regranulate used as feedstock for a new automotive component.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010128 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010128">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:label xml:lang="en">primary material</rdfs:label>
        <skos:definition xml:lang="en">A material entity produced from virgin raw resources and used for the first time in a production process.</skos:definition>
        <skos:example xml:lang="en">Virgin PA66 resin produced from primary chemical feedstocks.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010129 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010129">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">physical dimension</rdfs:label>
        <skos:definition xml:lang="en">A quality that characterizes a physical extent or dimensional feature of a material entity, product, component, or geometric feature.</skos:definition>
        <skos:example xml:lang="en">Length, width, thickness, or diameter used to characterize an automotive component.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010130 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010130">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0200002"/>
        <rdfs:label xml:lang="en">injection molding process</rdfs:label>
        <skos:definition xml:lang="en">An injection molding process in which plasticized material is injected into a mold cavity, held under pressure, cooled or solidified, and ejected as a shaped part.</skos:definition>
        <skos:example xml:lang="en">Injection molding of a PA66-GF25 connector housing.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010131 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010131">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000618"/>
        <rdfs:label xml:lang="en">Young&apos;s modulus</rdfs:label>
        <skos:definition xml:lang="en">An elastic modulus that quantifies the ratio of uniaxial stress to uniaxial strain in the linear elastic region of a material response.</skos:definition>
        <skos:example xml:lang="en">Young&apos;s modulus measured from a tensile test of a glass-fiber-reinforced polyamide specimen.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010140 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010140">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
        <rdfs:label xml:lang="en">unusual properties</rdfs:label>
        <skos:definition xml:lang="en">A data item that records noteworthy, unexpected, or abnormal properties observed for a component during use, inspection, dismantling, or circular economy assessment.</skos:definition>
        <skos:example xml:lang="en">A note that a component shows unusual discoloration or deformation compared with its expected state.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010141 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010141">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
        <rdfs:label xml:lang="en">actual dismantling time</rdfs:label>
        <skos:definition xml:lang="en">A realizable entity representing the observed time required to dismantle a product, vehicle, or component in a specific dismantling event.</skos:definition>
        <skos:example xml:lang="en">The measured time in minutes to remove a component from an end-of-life vehicle.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010142 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010142">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:label xml:lang="en">reason for selected R-strategy</rdfs:label>
        <skos:definition xml:lang="en">An information content entity that states the rationale for selecting a reuse, repair, remanufacturing, recycling, recovery, or disposal strategy for a product or component.</skos:definition>
        <skos:example xml:lang="en">A reason stating that reuse was rejected because mounting points were broken.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010143 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010143">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000033"/>
        <rdfs:label xml:lang="en">selected R-strategy</rdfs:label>
        <skos:definition xml:lang="en">A directive information entity that specifies the circular economy strategy selected for a product or component.</skos:definition>
        <skos:example xml:lang="en">A selected strategy of reuse, recycling, or remanufacturing for a dismantled component.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010144 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010144">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0010060"/>
        <rdfs:label xml:lang="en">actual dismantlability</rdfs:label>
        <skos:definition xml:lang="en">A disposition assessment that records how dismantlable a product or component was in an observed dismantling event.</skos:definition>
        <skos:example xml:lang="en">An actual dismantlability assessment from a dismantler after removing a door module.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010145 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010145">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0010022"/>
        <rdfs:label xml:lang="en">actual footprint of chosen R-strategy</rdfs:label>
        <skos:definition xml:lang="en">A carbon footprint amount that records the observed or calculated carbon dioxide equivalent burden of the selected circular economy strategy for a component.</skos:definition>
        <skos:example xml:lang="en">The kg CO2 equivalent resulting from choosing reuse for a dismantled component.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010146 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010146">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
        <rdfs:label xml:lang="en">vehicle condition</rdfs:label>
        <skos:definition xml:lang="en">A quality of a vehicle that characterizes its observed state relevant to use, dismantling, reuse, repair, recycling, or valuation.</skos:definition>
        <skos:example xml:lang="en">A vehicle condition assessment recorded at dismantling intake.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010147 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010147">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
        <rdfs:label xml:lang="en">drive type</rdfs:label>
        <skos:definition xml:lang="en">A quality of a vehicle that classifies its propulsion architecture or drive configuration.</skos:definition>
        <skos:example xml:lang="en">Battery electric drive, hybrid drive, or combustion engine drive.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010148 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010148">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000017"/>
        <rdfs:label xml:lang="en">empty weight</rdfs:label>
        <skos:definition xml:lang="en">A mass quality that quantifies the weight of a vehicle without load under the stated specification conditions.</skos:definition>
        <skos:example xml:lang="en">The empty weight in kilograms from vehicle documentation.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010149 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010149">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">vehicle type</rdfs:label>
        <skos:definition xml:lang="en">A quality of a vehicle that classifies the vehicle according to its design, construction, or intended purpose.</skos:definition>
        <skos:example xml:lang="en">Passenger car, light commercial vehicle, or heavy truck.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010150 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010150">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">corrosion</rdfs:label>
        <skos:definition xml:lang="en">A quality of a material, component, or surface indicating degradation by chemical or electrochemical reaction with its environment.</skos:definition>
        <skos:example xml:lang="en">Rust on a steel mounting bracket observed during dismantling.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010160 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010160">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:label xml:lang="en">model identifier</rdfs:label>
        <skos:definition xml:lang="en">An identifier assigned by an original equipment manufacturer to a vehicle model, vehicle project, or model variant.</skos:definition>
        <skos:example xml:lang="en">An OEM project code used to identify a vehicle model in product data.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010161 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010161">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:label xml:lang="en">vehicle series</rdfs:label>
        <skos:definition xml:lang="en">An identifier that records the vehicle series or platform series associated with a vehicle model or component.</skos:definition>
        <skos:example xml:lang="en">A vehicle series code used in dismantling or parts identification data.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010162 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010162">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000571"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/log/LOG_1000061"/>
        <rdfs:label xml:lang="en">OEM</rdfs:label>
        <skos:definition xml:lang="en">A manufacturer role borne by an organization that designs or produces the original vehicle, component, or system for which circular economy data is recorded.</skos:definition>
        <skos:example xml:lang="en">A vehicle manufacturer acting as original equipment manufacturer for a vehicle series.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010163 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010163">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0001933"/>
        <rdfs:label xml:lang="en">production date</rdfs:label>
        <skos:definition xml:lang="en">A date value specification that records when a vehicle, component, product, or material batch was produced.</skos:definition>
        <skos:example xml:lang="en">The production date of a vehicle read from manufacturer records.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010164 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010164">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0010093"/>
        <rdfs:label xml:lang="en">anonymized VIN</rdfs:label>
        <skos:definition xml:lang="en">An identifier derived from a vehicle identification number by anonymization or hashing so that the vehicle can be linked across records without exposing the original VIN.</skos:definition>
        <skos:example xml:lang="en">A hashed VIN used in circular economy data exchange.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0010165 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0010165">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:label xml:lang="en">name at manufacturer</rdfs:label>
        <skos:definition xml:lang="en">An identifier or designation by which a manufacturer names a material grade, product line, component, or product in its own records or commercial communication.</skos:definition>
        <skos:example xml:lang="en">A manufacturer trade name such as Ultradur, Zytel, or Grilamid.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0030000 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0030000">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000967"/>
        <rdfs:label xml:lang="en">melt temperature</rdfs:label>
        <skos:definition xml:lang="en">Temperature of the input melt in a manufacturing process</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0030001 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0030001">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0030000"/>
        <owl:disjointWith rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0030002"/>
        <rdfs:label xml:lang="en">max melt temperature</rdfs:label>
        <skos:definition xml:lang="en">Maximum temperature of the input melt in a manufacturing process</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0030002 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0030002">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0030000"/>
        <rdfs:label xml:lang="en">min melt temperature</rdfs:label>
        <skos:definition xml:lang="en">Minimum temperature of the input melt in a manufacturing process</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0030003 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0030003">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000967"/>
        <rdfs:label xml:lang="en">mold temperature</rdfs:label>
        <skos:definition xml:lang="en">Temperature of the mold used in a manufacturing process</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0030004 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0030004">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0030003"/>
        <owl:disjointWith rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0030005"/>
        <rdfs:label xml:lang="en">max mold temperature</rdfs:label>
        <skos:definition xml:lang="en">Maximum temperature of the mold used in a manufacturing process</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/automatce/AUTOMATCE_0030005 -->

    <owl:Class rdf:about="https://w3id.org/pmd/automatce/AUTOMATCE_0030005">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/automatce/AUTOMATCE_0030003"/>
        <rdfs:label xml:lang="en">min mold temperature</rdfs:label>
        <skos:definition xml:lang="en">Minimum temperature of the mold used in a manufacturing process</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000000 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000000">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000001"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000053"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000005"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000086"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Instances of Portions Of Matter whose shape is relevant for their dispostion to participate in a manufacturing process may be (subclasses of) objects that bear a &apos;blank role&apos; in the context of the manufacturing process.</rdfs:comment>
        <rdfs:comment xml:lang="en">Material is defined in terms of the three main perspectives that material specifications rely on: the structure of the material (&quot;intensive quality&quot;), the performance of the material (&quot;behavoiral material property&quot;) and the processing the material must have undergone (&quot;output of some process&quot;).

When defining specific materials/material taxonomies, these three aspects shall be taken into account in the aristotelian (&quot;per genus et differentiam&quot;) as differentiation.</rdfs:comment>
        <rdfs:comment xml:lang="en">The sum of portions of matter of the same type form a portion of matter of that type.</rdfs:comment>
        <rdfs:label xml:lang="de">Material</rdfs:label>
        <rdfs:label xml:lang="en">material</rdfs:label>
        <skos:altLabel xml:lang="en">Portion of Material</skos:altLabel>
        <skos:definition xml:lang="en">A material is a portion of matter that may participate in some manufacturing process and whose shape is not relevant for its participation in the manufacturing process.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000001 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000001">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:comment xml:lang="en">It is also representing a distinct physical or conceptual part of a material or substance.

The open energy ontology OEO defines portion of matter as a subclass of object aggregate, which implies countability. Our portion is not (precisely) countable and thus bearer of intensive properties.</rdfs:comment>
        <rdfs:comment xml:lang="en">Lome explanation for portion of matter: &quot;What is a molecule cluster at the cellular level? Contrary to the molecular level, at the cellular level of granularity the boundary of each molecule is outside of the level of granular focus. What forms a discontinuous cluster of countable individual molecules and thus bona fide objects at the molecular level, is a continuous and non-countable molecular substance at coarser levels of
granularity. At these coarser levels, the individual molecules cannot be differentiated and demarcated anymore and the cluster as a whole possesses only fiat inner boundaries.&quot;</rdfs:comment>
        <rdfs:label xml:lang="en">portion of matter</rdfs:label>
        <skos:definition xml:lang="en">A material entity that is not demarcated by any physical discontinuities. At some finer level of granularity it is an object aggregate, at some coarser level of granularity it is a fiat object part,but at this level of granularity it is neither.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000002 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000002">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000000"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000833"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000833"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">We recognize that some of the materials in the subclasses also occur naturally. However, these are not within the scope of our consideration for technical use.</rdfs:comment>
        <rdfs:label xml:lang="en">engineered material</rdfs:label>
        <skos:definition xml:lang="en">An engineered material is a material that is output of a manufacturing process.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000005 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000005">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000950"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf rdf:nodeID="genid116"/>
        <rdfs:comment xml:lang="en">A property is a material trait in terms of the kind and magnitude of response to a specific imposed stimulus. Generally, definitions of properties are made independent of material shape and size.
(Callister, W.D., Rethwisch, D.G., Materials Science and Engineering, Wiley, 2014)

Technical materials are complex aggregates. Many properties that are determined for those aggregates are intrinsically associated with the methodologies employed in the measurement process. This is in contrast to typical &apos;physical&apos; properties, which like e.g. mass that can be determined to high accuracy independently of the measurement process. 
As a consequence, material properties in the ontology are differeciated according to their measurement method, e.g. Brinell hardness and Vickers hardness are different types of indentation hardness rather than different measures/quantification (GDC) of the materials property &apos;indentation hardness&apos;.
 The &apos;unit idenifieres&apos; of such properties (e.g. &quot;HV1&quot;, &quot;HV10&quot;, &quot;HBW&quot;) are strictly speaking not units but rather references to the measurement methodology used to determine a numeric value that quantifies the property.

Extensive properties that depend on the object being tested rather than on the portion of matter are (extensive) object- or system-properties.</rdfs:comment>
        <rdfs:label xml:lang="en">material property</rdfs:label>
        <skos:definition xml:lang="en">a disposition of a portion of matter that is realized in a compatible process and whose realization is grounded in the portions intensive qualities</skos:definition>
    </owl:Class>
    <owl:Restriction rdf:nodeID="genid116">
        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
        <owl:someValuesFrom>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000001"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000056"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:someValuesFrom>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://w3id.org/pmd/co/PMD_0000005"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="genid116"/>
        <rdfs:comment xml:lang="en">Due to the duality of object and portion of matter this axiom can not be an equivalent class axiom.</rdfs:comment>
    </owl:Axiom>
    


    <!-- https://w3id.org/pmd/co/PMD_0000008 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000008">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000003"/>
        <rdfs:comment xml:lang="en">Process attribute for a process has a similar application to specifically dependened continuant (SDC) for an independent continuant (IC). Furthermore, process attribute describes how SDCs of some participants, i.e., ICs, change in a process. 

Specific rates, e.g., tensile rate, cooling rate, etc. should be added as  subclasses of this class.</rdfs:comment>
        <rdfs:label xml:lang="en">process attribute</rdfs:label>
        <skos:altLabel xml:lang="en">process characteristic</skos:altLabel>
        <skos:definition xml:lang="en">a process attribute is a dependent occurrent that existentially depends on a process.</skos:definition>
        <skos:example xml:lang="en">Tensile rate in a tensile testing process. Cooling rate in a quenching process</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000075 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000075">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="en-us">mold</rdfs:label>
        <rdfs:label xml:lang="en">mould</rdfs:label>
        <skos:definition xml:lang="en">A device consisting of a hollowed-out cavity that shapes fluid or plastic material into a specific form through the process of solidification or cooling.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000110 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000110">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">geological process</rdfs:label>
        <skos:definition xml:lang="en">A natural process that operates within the Earth system to transform, transport, or deform Earth materials, thereby changing Earth structures and landforms</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000503 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000503">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020243"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000417"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000109"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                                <owl:someValuesFrom>
                                    <owl:Class>
                                        <owl:intersectionOf rdf:parseType="Collection">
                                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000015"/>
                                            <owl:Restriction>
                                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/STATO_0000102"/>
                                                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0000104"/>
                                            </owl:Restriction>
                                        </owl:intersectionOf>
                                    </owl:Class>
                                </owl:someValuesFrom>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">ASTM grainsize</rdfs:label>
        <skos:definition xml:lang="en">The ASTM grain size is a quality that is measured through a process that follows the ASTM standard.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000512 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000512">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/pmd/co/PMD_0020116"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020116"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">aggregate state</rdfs:label>
        <skos:definition xml:lang="en">an intensive quality representing the physical state of a material, such as solid, liquid, or gasous</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000519 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000519">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">flow of electric charge</rdfs:label>
        <skos:definition xml:lang="en">is the process of movement of charged particles</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000520 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000520">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">heat flow</rdfs:label>
        <skos:definition xml:lang="en">is a process in which transfer of thermal energy between or within material entities occurs</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000521 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000521">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">generation of magnetic field</rdfs:label>
        <skos:definition xml:lang="en">is a process that occurs as a reaction to change of elctric field or movement of charges and produces a magnetic field</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000522 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000522">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">mechanical process</rdfs:label>
        <skos:definition xml:lang="en">is a process in which forces, moments, or imposed displacements to objects or object aggregates occur and/or the equivalent (stresses, strains) to materials or portions of matter</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000538 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000538">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000027"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000030"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">bulk</rdfs:label>
        <skos:definition xml:lang="en">The bulk is a fiat object part that describes the volume or mass of material considered as a whole, often in contrast to surface or interface phenomena.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000549 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000549">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">change of temperature</rdfs:label>
        <skos:definition xml:lang="en">change of temperature is a process in which a particpant changes its temperature</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000577 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000577">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000890"/>
        <rdfs:label xml:lang="en">composite</rdfs:label>
        <skos:definition xml:lang="en">An object aggregate that consists of two or more bonded materials with dissimilar physical or chemical properties which are used to complement each other where the parts remain seperate and distinct in the resulting object aggregate.</skos:definition>
        <skos:example>carbon fibre reinforced polymer
laminated glass
wood
hard metal composites for abrasive tools</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000583 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000583">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000293"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000299"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="de">Datenverarbeitung</rdfs:label>
        <rdfs:label xml:lang="de">Rechenprozess</rdfs:label>
        <rdfs:label xml:lang="en">computing process</rdfs:label>
        <skos:definition xml:lang="en">A process that involves the systematic use of computational methods and tools to perform simulations, analyses, or data transformations to achieve specific scientific or engineering goals.</skos:definition>
        <skos:definition xml:lang="de">Ein Prozess, der die systematische Verwendung von rechnerischen Methoden und Werkzeugen umfasst, um Simulationen, Analysen oder Datenumwandlungen durchzuführen, um spezifische wissenschaftliche oder technische Ziele zu erreichen.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000591 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000591">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/pmd/co/PMD_0020099"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020099"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The finite set of periodic geometric arrangements is described e.g. by the 14 possible Bravais Lattices in three-dimensional space.</rdfs:comment>
        <rdfs:label xml:lang="en">crystal structure</rdfs:label>
        <skos:definition xml:lang="en">an intensive qualtty of a crystal that embodies the periodic geometric arrangement of entities in a crystal lattice.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000595 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000595">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:label xml:lang="en">defect density</rdfs:label>
        <skos:definition xml:lang="en">an intensive quality describing the number of defects per unit volume or area in a material, which can affect its mechanical and electronic properties</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000596 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000596">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">deformation</rdfs:label>
        <skos:definition xml:lang="en">The deformation is a process describing a change in the shape, size, or structure of a material often under the influence of stress or force.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000597 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000597">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020131"/>
        <rdfs:label xml:lang="en">density</rdfs:label>
        <skos:definition xml:lang="en">The density is a universal intensive quality representing the unit mass of a portion of matter per unit volume.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000602 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000602">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="de">Gerät</rdfs:label>
        <rdfs:label xml:lang="en">device</rdfs:label>
        <skos:definition xml:lang="en">A device is an object that is designed to perform a specific function or task involving measurement, manipulation, processing, or analysis.</skos:definition>
        <skos:definition xml:lang="de">Ein physisches oder virtuelles Objekt, das verwendet wird, um eine bestimmte Funktion oder Aufgabe auszuführen, häufig im Zusammenhang mit der Messung, Manipulation oder Analyse von Materialien.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000618 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000618">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000949"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000052"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000027"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000030"/>
                            <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000538"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">elastic modulus</rdfs:label>
        <skos:definition xml:lang="en">represents a material&apos;s stiffness, defined as the ratio of stress to strain in the elastic deformation region.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000629 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000629">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">emission of radiation</rdfs:label>
        <skos:definition xml:lang="en">The emission radiation is a process describing the release of energy in the form of electromagnetic waves or particles from a material.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000635 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000635">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">evolution of damage</rdfs:label>
        <skos:definition xml:lang="en">An evolution of damage is a process representing the progression of material degradation under mechanical, thermal, or chemical stresses.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000654 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000654">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/co/PMD_0000000"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000030"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000085"/>
                                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000034"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000030"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000085"/>
                                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000034"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">functional material</rdfs:label>
        <skos:definition xml:lang="en">A functional material F is an engineered material which has the disposition to be used for an object O (O consists of F) and O&apos;s function is other/more than mechanical load carrying.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000661 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000661">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000000"/>
        <rdfs:comment xml:lang="en">It is often composed of silica-based compounds.</rdfs:comment>
        <rdfs:label xml:lang="en">glass</rdfs:label>
        <skos:definition xml:lang="en">A glass is an engineered material present as an amorphous solid typically formed by rapid cooling of a melt.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000663 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000663">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020003"/>
        <rdfs:label xml:lang="en">crystallite</rdfs:label>
        <rdfs:label xml:lang="de">kristallit</rdfs:label>
        <skos:altLabel xml:lang="de">Korn</skos:altLabel>
        <skos:altLabel xml:lang="en">grain</skos:altLabel>
        <skos:definition xml:lang="en">A crystal grain is a crystal that is part of a polycrystal.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000773 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000773">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000848"/>
        <rdfs:label xml:lang="en">hardness</rdfs:label>
        <skos:definition xml:lang="en">The hardness is a mechanical property used as a measure of a material&apos;s resistance to localized plastic deformation, often tested by indentation or scratch methods.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000777 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000777">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000981"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0001029"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000549"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">heat capacity</rdfs:label>
        <skos:definition xml:lang="en">The heat capacity is a thermal property describing the amount of heat energy required to raise the temperature of a material by a given amount.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000790 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000790">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000877"/>
        <rdfs:comment xml:lang="en">e.g., air into glass</rdfs:comment>
        <rdfs:label xml:lang="en">refraction (optical)</rdfs:label>
        <skos:definition xml:lang="en">Optical property which describes the bending of light as it passes from one medium into another due to a change in the light’s speed.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000794 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000794">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000602"/>
        <rdfs:label xml:lang="de">Spritzgießmaschine</rdfs:label>
        <rdfs:label xml:lang="en">injection molding machine</rdfs:label>
        <skos:definition xml:lang="en">An injection molding machine is a device used to produce plastic parts by injecting molten plastic into molds under high pressure.</skos:definition>
        <skos:definition xml:lang="de">Eine Spritzgießmaschine ist ein Gerät, das verwendet wird, um Kunststoffteile durch Einspritzen von geschmolzenem Kunststoff in Formen unter hohem Druck herzustellen.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000802 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000802">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">absorption of radiation</rdfs:label>
        <skos:definition xml:lang="en">process of taking up radiation by a material entity</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/co/PMD_0000833 -->

    <owl:Class rdf:about="https://w3id.org/pmd/co/PMD_0000833">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/COB_0000035"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000293"/>
