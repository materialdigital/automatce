     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:prov="http://www.w3.org/ns/prov#"
     xmlns:rdfa="http://www.w3.org/ns/rdfa#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:void="http://rdfs.org/ns/void#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:oboInOwl="http://www.geneontology.org/formats/oboInOwl#">
    <owl:Ontology rdf:about="https://w3id.org/pmd/automatce.owl">
        <owl:versionIRI rdf:resource="https://w3id.org/pmd/automatce/releases/2026-04-27/automatce.owl"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-0473-0070"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-0744-8855"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-1503-4422"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0007-7468-3544"/>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0003-0473-0070"/>
        <dcterms:creator rdf:resource="https://orcid.org/0000-0003-0744-8855"/>
        <dcterms:creator rdf:resource="https://orcid.org/0009-0003-1503-4422"/>
        <dcterms:creator rdf:resource="https://orcid.org/0009-0007-7468-3544"/>
        <dcterms:description>Application ontology for automotive circular-economy product, material, sustainability, usage, dismantling, engineering and transactional data aligned to PMDCore and BFO 2020.</dcterms:description>
        <dcterms:license rdf:resource="https://w3id.org/pmd/automatce.owl#CC-BY-4.0"/>
        <dcterms:title>Automotive Circular Economy Ontology</dcterms:title>
        <owl:versionInfo>2026-04-27</owl:versionInfo>
    </owl:Ontology>
    


